  }, {
    "@id" : "http://www.w3.org/ns/shacl#"
  }, {
    "@id" : "https://semiceu.github.io/CPSV-AP/releases/3.2.0/"
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#"
  } ],
  "http://www.w3.org/2002/07/owl#priorVersion" : [ {
    "@value" : "0.1.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "0.2.0-core"
  } ],
  "http://www.w3.org/2004/02/skos/core#changeNote" : [ {
    "@language" : "en",
    "@value" : "Core ontology contains only core classess and properties."
  }, {
    "@language" : "fi",
    "@value" : "Ydinontologia sisältää ainoastaan ydinluokat ja ominaisuudet."
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Sosiaaliturvan tietämysgraafi (KELAO) ei sisällä hakijakohtaisia tietoja — henkilötiedot käsitellään Kelan operatiivisissa järjestelmissä."
  }, {
    "@language" : "en",
    "@value" : "The Social Security knowledge graph (KELAO) does not contain applicant-level data — personal data is processed in Kela's operational systems."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Appeal",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Appeal"
  }, {
    "@language" : "fi",
    "@value" : "Muutoksenhaku"
  }, {
    "@language" : "sv",
    "@value" : "Ändringssökande"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Entity"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fi",
    "@value" : "oikaisuvaatimus"
  }, {
    "@language" : "fi",
    "@value" : "valitus"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An applicant's request for rectification of or appeal against a decision."
  }, {
    "@language" : "fi",
    "@value" : "Hakijan päätökseen kohdistama oikaisuvaatimus tai valitus."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Appeal"
  }, {
    "@language" : "fi",
    "@value" : "Muutoksenhaku"
  }, {
    "@language" : "sv",
    "@value" : "Ändringssökande"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Applicant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Applicant"
  }, {
    "@language" : "fi",
    "@value" : "Hakija"
  }, {
    "@language" : "sv",
    "@value" : "Sökande"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Agent"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A natural or legal person who applies for a benefit or service, or to whom the right to apply has been transferred."
  }, {
    "@language" : "fi",
    "@value" : "Henkilö tai oikeushenkilö, joka hakee etuutta tai palvelua, tai jolle hakuoikeus on siirtynyt."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Applicant"
  }, {
    "@language" : "fi",
    "@value" : "Hakija"
  }, {
    "@language" : "sv",
    "@value" : "Sökande"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Hakija on prosessirooli. kelao:User on sovelluksen käyttäjä; sama henkilö voi olla molempia."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Application",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sv",
    "@value" : "Ansökan"
  }, {
    "@language" : "en",
    "@value" : "Application"
  }, {
    "@language" : "fi",
    "@value" : "Hakemus"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Entity"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An applicant's request for a benefit or service. Filing initiates processing of the case."
  }, {
    "@language" : "fi",
    "@value" : "Hakijan etuutta tai palvelua koskeva hakemus. Hakemuksen vireilletulo käynnistää asian käsittelyn."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "sv",
    "@value" : "Ansökan"
  }, {
    "@language" : "en",
    "@value" : "Application"
  }, {
    "@language" : "fi",
    "@value" : "Hakemus"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "Conceptual class only. The KELAO knowledge graph does not contain applicant-level instances — personal data is processed in Kela's operational systems."
  }, {
    "@language" : "fi",
    "@value" : "Käsitteellinen luokka. KELAO-tietämysgraafi ei sisällä hakijakohtaisia instansseja — henkilötiedot käsitellään Kelan operatiivisissa järjestelmissä."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Attachment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An application attachment, e.g. a receipt, certificate or form."
  }, {
    "@language" : "fi",
    "@value" : "Hakemuksen liite, esim. tosite, todistus tai lomake."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Attachment"
  }, {
    "@language" : "sv",
    "@value" : "Bilaga"
  }, {
    "@language" : "fi",
    "@value" : "Liite"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://schema.org/DigitalDocument"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fi",
    "@value" : "Hakemukseen liitettävä lisämateriaali, joka täydentää tai todentaa hakemuksen tietoja."
  }, {
    "@language" : "en",
    "@value" : "Supplementary material attached to an application that completes or substantiates the application's information."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Attachment"
  }, {
    "@language" : "sv",
    "@value" : "Bilaga"
  }, {
    "@language" : "fi",
    "@value" : "Liite"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Liitettä tarvitaan joskus hakemuksen liitteeksi; pakollisuus on hakemus- tai etuuskohtaista (kuvataan SHACLissa, ei luokkatasolla)."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Benefit",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A social security benefit or allowance. General class — use subclasses for instances."
  }, {
    "@language" : "fi",
    "@value" : "Sosiaaliturvan etuus tai tuki. Yleinen luokka — käytä alaluokkia instansseissa."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Benefit"
  }, {
    "@language" : "fi",
    "@value" : "Etuus"
  }, {
    "@language" : "sv",
    "@value" : "Förmån"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/vocab/cpsv#PublicService"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Social benefit"
  }, {
    "@language" : "fi",
    "@value" : "Sosiaalietuus"
  }, {
    "@language" : "fi",
    "@value" : "Tuki"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Benefit"
  }, {
    "@language" : "fi",
    "@value" : "Etuus"
  }, {
    "@language" : "sv",
    "@value" : "Förmån"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#BenefitComponent",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Benefit Component"
  }, {
    "@language" : "fi",
    "@value" : "Osa suurempaa etuuskokonaisuutta."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Benefit Component"
  }, {
    "@language" : "fi",
    "@value" : "Etuuden osa"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://kela.fi/ontology/kelao#Benefit"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://kela.fi/ontology/kelao#StandaloneBenefit"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fi",
    "@value" : "etuusosa"
  }, {
    "@language" : "en",
    "@value" : "sub-benefit"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An independent and separately processed part of a benefit that can be granted only if the benefit in which the part belongs is also granted."
  }, {
    "@language" : "fi",
    "@value" : "Etuuden itsenäinen, erikseen käsiteltävä osa, joka voidaan myöntää vain, jos myös etuus, jonka osa on kyseessä, on myönnetty."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fi",
    "@value" : "Esimerkiksi opintotuessa etuuden osia ovat opintoraha, asumislisä ja opintolainan valtiontakaus; lesken- ja lapseneläkkeessä osia ovat perus- ja täydennysmäärät."
  }, {
    "@language" : "en",
    "@value" : "For example, the study grant, housing supplement and government guarantee for student loan are parts of the financial aid for students."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Benefit Component"
  }, {
    "@language" : "fi",
    "@value" : "Etuuden osa"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#BenefitGroup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Benefit group"
  }, {
    "@language" : "fi",
    "@value" : "Kelan etuusryhmitys"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Benefit Group"
  }, {
    "@language" : "fi",
    "@value" : "Etuusryhmä"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Benefit Group"
  }, {
    "@language" : "fi",
    "@value" : "Etuusryhmä"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Decision",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sv",
    "@value" : "Beslut"
  }, {
    "@language" : "en",
    "@value" : "Decision"
  }, {
    "@language" : "fi",
    "@value" : "Päätös"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Entity"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An authority's resolution on an application; grants or rejects the requested benefit in full or in part."
  }, {
    "@language" : "fi",
    "@value" : "Viranomaisen ratkaisu hakemukseen; myöntää tai hylkää haetun etuuden kokonaan tai osittain."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "sv",
    "@value" : "Beslut"
  }, {
    "@language" : "en",
    "@value" : "Decision"
  }, {
    "@language" : "fi",
    "@value" : "Päätös"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#LegalResource",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A work in a legislative corpus. This applies to acts that have been legally enacted (whether or not they are still in force). A legal resource can represent a legal act or any component of a legal act, like an article. Legal resources can be linked together using properties defined in the model."
  }, {
    "@language" : "fi",
    "@value" : "Lainsäädäntöaineistoon kuuluva teos. Tämä koskee lainvoimaisesti säädettyjä lakeja (riippumatta siitä, ovatko ne vielä voimassa). Oikeudellinen resurssi voi edustaa säädöstä tai mitä tahansa säädöksen osaa, kuten artiklaa. Oikeudelliset resurssit voidaan linkittää toisiinsa mallissa määriteltyjen ominaisuuksien avulla."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sv",
    "@value" : "Juridisk resurs"
  }, {
    "@language" : "en",
    "@value" : "Legal Resource"
  }, {
    "@language" : "fi",
    "@value" : "Säädös"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://data.europa.eu/eli/ontology#LegalResource"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fi",
    "@value" : "Tekstikokonaisuus, joka sisältää julkisen vallan antamia yleisesti noudatettaviksi tarkoitettuja säännöksiä."
  }, {
    "@language" : "en",
    "@value" : "Text containing provisions issued by public authorities that are to be observed generally."
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://schema.org/Legislation"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "Examples of statutes are acts and decrees as well as legal provisions issued by authorities."
  }, {
    "@language" : "fi",
    "@value" : "Säädöksiä ovat esimerkiksi lait ja asetukset sekä viranomaisten antamat oikeussäännöt."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#LegalResourcePart",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fi",
    "@value" : "Lain tai asetuksen osa (luku, pykälä, momentti, kohta yms.).\n          Tämä luokka on tarkoitettu erottamaan kokonaiset lait niiden osista. EU-asetuksissa ym. on myös muu jaottelu kuin Suomessa."
  }, {
    "@language" : "en",
    "@value" : "Legal Resource Part"
  }, {
    "@language" : "fi",
    "@value" : "Osa laista riippumatta siitä, onko kyseessä luku, pykälä vai momentti."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sv",
    "@value" : "Lagdel"
  }, {
    "@language" : "fi",
    "@value" : "Lain osa"
  }, {
    "@language" : "en",
    "@value" : "Legal Resource Part"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://data.europa.eu/eli/ontology#LegalResource"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fi",
    "@value" : "Lain tai asetuksen osa riippumatta siitä, onko kyseessä luku, pykälä vai momentti"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fi",
    "@value" : "Kansaneläkelain 23 §"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "sv",
    "@value" : "Lagdel"
  }, {
    "@language" : "fi",
    "@value" : "Lain osa"
  }, {
    "@language" : "en",
    "@value" : "Legal Resource Part"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#LifeSituationClassification",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class", "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fi",
    "@value" : "Elämäntilanteilla tarkoitetaan sellaisia muutosvaiheita, joita kuvaa väliaikaisuus, erityisten palvelujen ja tiedon tarve sekä niihin kohdennetut palvelut.\n        Elämäntilanneluokitus on toteutettu muualla skos-luokituksena. Luokituksen luokat ovat käsitteitä. Luokitus on luonnos. Pohjana on käytetty\n        DVV:n elämäntapahtumaluokitusta, joka perustuu EU-luokitukseen."
  }, {
    "@language" : "en",
    "@value" : "Life situations refer to phases of change characterized by temporary nature, the need for special services and information, and services targeted to them."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fi",
    "@value" : "ElämäntilanneLuokitus"
  }, {
    "@language" : "sv",
