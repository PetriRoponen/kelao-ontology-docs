  "http://www.w3.org/2002/07/owl#priorVersion" : [ {
    "@value" : "0.2.0-core-draft"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://petriroponen.github.io/kelao-ontology-docs/"
  } ],
  "http://www.w3.org/2002/07/owl#versionInfo" : [ {
    "@value" : "0.3.0-core-draft"
  } ],
  "http://www.w3.org/2004/02/skos/core#changeNote" : [ {
    "@language" : "fi",
    "@value" : "0.3.0: lisätty maantieteelliset alueet (Location, Municipality, WellbeingServiceCounty, Region, Country), palvelukanava (ServiceChannel) ja palveluyksikkö (ServiceUnit) sekä tietotuote (DataProduct) relaatioineen ja ominaisuuksineen."
  }, {
    "@language" : "en",
    "@value" : "Automated document generation"
  }, {
    "@language" : "fi",
    "@value" : "Automatisoitu dokumentaation luonti .ttl-tiedostosta"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Sosiaaliturvan tietämysgraafi (KELAO) ei sisällä hakijakohtaisia tietoja — henkilötiedot käsitellään Kelan operatiivisissa järjestelmissä."
  }, {
    "@language" : "en",
    "@value" : "The Social Security knowledge graph (KELAO) does not contain applicant-level data — personal data is processed in Kela's operational systems."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Appeal",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Appeal"
  }, {
    "@language" : "fi",
    "@value" : "Muutoksenhaku"
  }, {
    "@language" : "sv",
    "@value" : "Ändringssökande"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Entity"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fi",
    "@value" : "oikaisuvaatimus"
  }, {
    "@language" : "fi",
    "@value" : "valitus"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An applicant's request for rectification of or appeal against a decision."
  }, {
    "@language" : "fi",
    "@value" : "Hakijan päätökseen kohdistama oikaisuvaatimus tai valitus."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Appeal"
  }, {
    "@language" : "fi",
    "@value" : "Muutoksenhaku"
  }, {
    "@language" : "sv",
    "@value" : "Ändringssökande"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Applicant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Applicant"
  }, {
    "@language" : "fi",
    "@value" : "Hakija"
  }, {
    "@language" : "sv",
    "@value" : "Sökande"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Agent"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A natural or legal person who applies for a benefit or service, or to whom the right to apply has been transferred."
  }, {
    "@language" : "fi",
    "@value" : "Henkilö tai oikeushenkilö, joka hakee etuutta tai palvelua, tai jolle hakuoikeus on siirtynyt."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Applicant"
  }, {
    "@language" : "fi",
    "@value" : "Hakija"
  }, {
    "@language" : "sv",
    "@value" : "Sökande"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Hakija on prosessirooli. kelao:User on sovelluksen käyttäjä; sama henkilö voi olla molempia."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Application",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sv",
    "@value" : "Ansökan"
  }, {
    "@language" : "en",
    "@value" : "Application"
  }, {
    "@language" : "fi",
    "@value" : "Hakemus"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://iri.suomi.fi/terminology/kela/c77"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Entity"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "sv",
    "@value" : "Ansökan om förmån"
  }, {
    "@language" : "fi",
    "@value" : "Etuushakemus"
  }, {
    "@language" : "sv",
    "@value" : "Förmånsansökan"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An applicant's request for a benefit or service. Filing initiates processing of the case."
  }, {
    "@language" : "fi",
    "@value" : "Asiakirja, jolla etuudenhakijalle esittää pyynnön tai hänen puolestaan ja hänen suostumuksellaan esitetään pyyntö saada jotain etuutta."
  }, {
    "@language" : "fi",
    "@value" : "Hakijan etuutta tai palvelua koskeva hakemus. Hakemuksen vireilletulo käynnistää asian käsittelyn. Etuushakemus on hakemuksen alaluokka."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "sv",
    "@value" : "Ansökan"
  }, {
    "@language" : "en",
    "@value" : "Application"
  }, {
    "@language" : "fi",
    "@value" : "Hakemus"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "Conceptual class only. The KELAO knowledge graph does not contain applicant-level instances — personal data is processed in Kela's operational systems."
  }, {
    "@language" : "fi",
    "@value" : "Käsitteellinen luokka. KELAO-tietämysgraafi ei sisällä hakijakohtaisia instansseja — henkilötiedot käsitellään Kelan operatiivisissa järjestelmissä."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Attachment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An application attachment, e.g. a receipt, certificate or form."
  }, {
    "@language" : "fi",
    "@value" : "Hakemuksen liite, esim. tosite, todistus tai lomake."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Attachment"
  }, {
    "@language" : "sv",
    "@value" : "Bilaga"
  }, {
    "@language" : "fi",
    "@value" : "Liite"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://schema.org/DigitalDocument"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fi",
    "@value" : "Hakemukseen liitettävä lisämateriaali, joka täydentää tai todentaa hakemuksen tietoja."
  }, {
    "@language" : "en",
    "@value" : "Supplementary material attached to an application that completes or substantiates the application's information."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Attachment"
  }, {
    "@language" : "sv",
    "@value" : "Bilaga"
  }, {
    "@language" : "fi",
    "@value" : "Liite"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Liitettä tarvitaan joskus hakemuksen liitteeksi; pakollisuus on hakemus- tai etuuskohtaista (kuvataan SHACLissa, ei luokkatasolla)."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Benefit",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A social security benefit or allowance. General class — use subclasses for instances."
  }, {
    "@language" : "sv",
    "@value" : "FPA:s förmåner är sociala förmåner. Ibland används också termen socialförsäkringsförmåner."
  }, {
    "@language" : "fi",
    "@value" : "Sosiaaliturvan etuus tai tuki. Yleinen luokka — käytä alaluokkia instansseissa. Kelan etuudet ovat sosiaalietuuksia. Joskus käytetään myös termiä sosiaaliturvaetuus."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Benefit"
  }, {
    "@language" : "fi",
    "@value" : "Etuus"
  }, {
    "@language" : "sv",
    "@value" : "Förmån"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://iri.suomi.fi/terminology/verotus/c66"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/vocab/cpsv#PublicService"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Social benefit"
  }, {
    "@language" : "fi",
    "@value" : "Sosiaalietuus"
  }, {
    "@language" : "fi",
    "@value" : "Tuki"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "sv",
    "@value" : "Nyttighet vars ekonomiska värde kan fastställas och som beviljas utgående från mottagarens ställning eller livssituation på grunder som fastställts i förväg."
  }, {
    "@language" : "fi",
    "@value" : "Taloudelliselta arvoltaan määriteltävissä oleva hyödyke, joka myönnetään saajan aseman tai elämäntilanteen perusteella ennalta määritellyin perustein.\n            Verotus: suoritus, joka maksetaan saajan aseman tai elämäntilanteen perusteella ennalta määritellyin perustein\n            "
  }, {
    "@language" : "en",
    "@value" : "x"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "https://iri.suomi.fi/terminology/kela/c60"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Benefit"
  }, {
    "@language" : "fi",
    "@value" : "Etuus"
  }, {
    "@language" : "sv",
    "@value" : "Förmån"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#BenefitComponent",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Benefit Component"
  }, {
    "@language" : "fi",
    "@value" : "Osa suurempaa etuuskokonaisuutta."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Benefit Component"
  }, {
    "@language" : "fi",
    "@value" : "Etuuden osa"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://kela.fi/ontology/kelao#Benefit"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "https://kela.fi/ontology/kelao#StandaloneBenefit"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fi",
    "@value" : "etuusosa"
  }, {
    "@language" : "en",
    "@value" : "sub-benefit"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An independent and separately processed part of a benefit that can be granted only if the benefit in which the part belongs is also granted."
  }, {
    "@language" : "fi",
    "@value" : "Etuuden itsenäinen, erikseen käsiteltävä osa, joka voidaan myöntää vain, jos myös etuus, jonka osa on kyseessä, on myönnetty."
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fi",
    "@value" : "Esimerkiksi opintotuessa etuuden osia ovat opintoraha, asumislisä ja opintolainan valtiontakaus; lesken- ja lapseneläkkeessä osia ovat perus- ja täydennysmäärät."
  }, {
    "@language" : "en",
    "@value" : "For example, the study grant, housing supplement and government guarantee for student loan are parts of the financial aid for students."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Benefit Component"
  }, {
    "@language" : "fi",
    "@value" : "Etuuden osa"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#BenefitGroup",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Benefit group"
  }, {
    "@language" : "fi",
    "@value" : "Kelan etuusryhmitys"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Benefit Group"
  }, {
    "@language" : "fi",
    "@value" : "Etuusryhmä"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Benefit Group"
  }, {
    "@language" : "fi",
    "@value" : "Etuusryhmä"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Country",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A country / state. Used e.g. to express residence requirements and cross-border situations."
  }, {
    "@language" : "fi",
    "@value" : "Valtio. Käytetään esim. asumisedellytyksen ja kansainvälisten tilanteiden kuvaamiseen."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Country"
  }, {
    "@language" : "sv",
    "@value" : "Stat"
  }, {
    "@language" : "fi",
    "@value" : "Valtio"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://kela.fi/ontology/kelao#Location"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://schema.org/Country"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Country"
  }, {
    "@language" : "sv",
    "@value" : "Stat"
  }, {
    "@language" : "fi",
    "@value" : "Valtio"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Lähdeontologiassa kuvattu suoraan schema:Country-luokkana; ydinmallissa määritelty omana luokkana ja linkitetty skos:exactMatch-suhteella."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#DataProduct",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A managed and governed collection of data with a purpose, value, ownership and life-cycle that meets consumer needs, e.g. a report or other benefit-related data product."
  }, {
    "@language" : "fi",
    "@value" : "Hallittu ja omistettu tietokokonaisuus, jolla on tarkoitus, arvo ja elinkaari ja joka vastaa tiedon hyödyntäjän tarpeisiin. Esimerkiksi raportti tai muu etuuteen liittyvä tietotuote."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Data Product"
  }, {
    "@language" : "sv",
    "@value" : "Informationsprodukt"
  }, {
    "@language" : "fi",
    "@value" : "Tietotuote"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A data product is a product that facilitates an end goal through the use of data."
  }, {
    "@language" : "fi",
    "@value" : "Tietotuote on tuote, joka helpottaa lopputavoitteen saavuttamista datan avulla."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Data Product"
  }, {
    "@language" : "sv",
    "@value" : "Informationsprodukt"
  }, {
    "@language" : "fi",
    "@value" : "Tietotuote"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Itsenäinen luokka. Mahdollinen linkitys ulkoiseen data product -sanastoon (esim. DPROD) jätetty myöhempään harmonisointiin."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Decision",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sv",
    "@value" : "Beslut"
  }, {
    "@language" : "en",
    "@value" : "Decision"
  }, {
    "@language" : "fi",
    "@value" : "Päätös"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "https://iri.suomi.fi/terminology/kela/c78"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/prov#Entity"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "sv",
    "@value" : "beslut om förmån"
  }, {
    "@language" : "fi",
    "@value" : "etuuspäätös"
  }, {
    "@language" : "sv",
    "@value" : "förmånsbeslut"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An authority's resolution on an application; grants or rejects the requested benefit in full or in part."
  }, {
    "@language" : "fi",
    "@value" : "Viranomaisen ratkaisu hakemukseen; myöntää tai hylkää haetun etuuden kokonaan tai osittain."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "sv",
    "@value" : "Beslut"
  }, {
    "@language" : "en",
    "@value" : "Decision"
  }, {
    "@language" : "fi",
    "@value" : "Päätös"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#LegalResource",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A work in a legislative corpus. This applies to acts that have been legally enacted (whether or not they are still in force). A legal resource can represent a legal act or any component of a legal act, like an article. Legal resources can be linked together using properties defined in the model."
  }, {
    "@language" : "fi",
    "@value" : "Lainsäädäntöaineistoon kuuluva teos. Tämä koskee lainvoimaisesti säädettyjä lakeja (riippumatta siitä, ovatko ne vielä voimassa). Oikeudellinen resurssi voi edustaa säädöstä tai mitä tahansa säädöksen osaa, kuten artiklaa. Oikeudelliset resurssit voidaan linkittää toisiinsa mallissa määriteltyjen ominaisuuksien avulla."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sv",
    "@value" : "Juridisk resurs"
  }, {
    "@language" : "en",
    "@value" : "Legal Resource"
  }, {
    "@language" : "fi",
    "@value" : "Säädös"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://data.europa.eu/eli/ontology#LegalResource"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fi",
    "@value" : "Tekstikokonaisuus, joka sisältää julkisen vallan antamia yleisesti noudatettaviksi tarkoitettuja säännöksiä."
  }, {
    "@language" : "en",
    "@value" : "Text containing provisions issued by public authorities that are to be observed generally."
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://schema.org/Legislation"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "en",
    "@value" : "Examples of statutes are acts and decrees as well as legal provisions issued by authorities."
  }, {
    "@language" : "fi",
    "@value" : "Säädöksiä ovat esimerkiksi lait ja asetukset sekä viranomaisten antamat oikeussäännöt."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#LegalResourcePart",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fi",
    "@value" : "Lain tai asetuksen osa (luku, pykälä, momentti, kohta yms.).\n          Tämä luokka on tarkoitettu erottamaan kokonaiset lait niiden osista. EU-asetuksissa ym. on myös muu jaottelu kuin Suomessa."
  }, {
    "@language" : "en",
    "@value" : "Legal Resource Part"
  }, {
    "@language" : "fi",
    "@value" : "Osa laista riippumatta siitä, onko kyseessä luku, pykälä vai momentti."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sv",
    "@value" : "Lagdel"
  }, {
    "@language" : "fi",
    "@value" : "Lain osa"
  }, {
    "@language" : "en",
    "@value" : "Legal Resource Part"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://data.europa.eu/eli/ontology#LegalResource"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fi",
    "@value" : "Lain tai asetuksen osa riippumatta siitä, onko kyseessä luku, pykälä vai momentti"
  } ],
  "http://www.w3.org/2004/02/skos/core#example" : [ {
    "@language" : "fi",
    "@value" : "Kansaneläkelain 23 §"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "sv",
    "@value" : "Lagdel"
  }, {
    "@language" : "fi",
    "@value" : "Lain osa"
  }, {
    "@language" : "en",
    "@value" : "Legal Resource Part"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#LifeSituationClassification",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fi",
    "@value" : "Elämäntilanteilla tarkoitetaan sellaisia muutosvaiheita, joita kuvaa väliaikaisuus, erityisten palvelujen ja tiedon tarve sekä niihin kohdennetut palvelut.\n        Elämäntilanneluokitus on toteutettu muualla skos-luokituksena. Luokituksen luokat ovat käsitteitä. Luokitus on luonnos. Pohjana on käytetty\n        DVV:n elämäntapahtumaluokitusta, joka perustuu EU-luokitukseen."
  }, {
    "@language" : "en",
    "@value" : "Life situations refer to phases of change characterized by temporary nature, the need for special services and information, and services targeted to them."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fi",
    "@value" : "ElämäntilanneLuokitus"
  }, {
    "@language" : "sv",
    "@value" : "Klassificering av livssituationer"
  }, {
    "@language" : "en",
    "@value" : "Life Situation Classification"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2004/02/skos/core#closeMatch" : [ {
    "@id" : "http://iri.suomi.fi/model/suomiptv2/LifeEventClassification"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fi",
    "@value" : "Elämäntilanteilla tarkoitetaan sellaisia muutosvaiheita, joita kuvaa väliaikaisuus, erityisten palvelujen ja tiedon tarve sekä niihin kohdennetut palvelut."
  }, {
    "@language" : "en",
    "@value" : "Life situations refer to phases of change characterized by temporary nature, the need for special services and information, and services targeted to them."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fi",
    "@value" : "ElämäntilanneLuokitus"
  }, {
    "@language" : "sv",
    "@value" : "Klassificering av livssituationer"
  }, {
    "@language" : "en",
    "@value" : "Life Situation Classification"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Location",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A geographic area used e.g. to describe a place of residence, a service operating area, or the location of a service unit. Superclass for municipalities, wellbeing service counties, regions and countries."
  }, {
    "@language" : "fi",
    "@value" : "Maantieteellinen alue, jota voidaan käyttää esim. asuinpaikan, palvelun toiminta-alueen tai palveluyksikön sijainnin kuvaamiseen. Yliluokka kunnille, hyvinvointialueille, maakunnille ja valtioille."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Location"
  }, {
    "@language" : "sv",
    "@value" : "Plats"
  }, {
    "@language" : "fi",
    "@value" : "Sijainti"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "en",
    "@value" : "Geographic Area"
  }, {
    "@language" : "fi",
    "@value" : "Maantieteellinen alue"
  } ],
  "http://www.w3.org/2004/02/skos/core#closeMatch" : [ {
    "@id" : "http://www.w3.org/ns/locn#Location"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "Any geographic area, irrespective of size or administrative level."
  }, {
    "@language" : "fi",
    "@value" : "Mikä tahansa maantieteellinen alue koosta tai hallinnollisesta tasosta riippumatta."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "en",
    "@value" : "Location"
  }, {
    "@language" : "sv",
    "@value" : "Plats"
  }, {
    "@language" : "fi",
    "@value" : "Sijainti"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Vastaa lähdeontologian kelao:GeographicArea-luokkaa; ydinmallissa nimi on harmonisoitu Location-muotoon ja linkitetty W3C Location Core -sanastoon (locn:Location)."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Municipality",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A Finnish municipality. Municipalities are identified using Suomi.fi code list URIs."
  }, {
    "@language" : "fi",
    "@value" : "Suomen kunta. Kunnat tunnistetaan Suomi.fi-koodiston URI-tunnisteilla."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sv",
    "@value" : "Kommun"
  }, {
    "@language" : "fi",
    "@value" : "Kunta"
  }, {
    "@language" : "en",
    "@value" : "Municipality"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://kela.fi/ontology/kelao#Location"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "sv",
    "@value" : "Kommun"
  }, {
    "@language" : "fi",
    "@value" : "Kunta"
  }, {
    "@language" : "en",
    "@value" : "Municipality"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Suomen kunnat, Suomi.fi URI:t."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Organisation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An actor that is an association of individuals with a common goal and a purposeful structure"
  }, {
    "@language" : "fi",
    "@value" : "Toimija, joka on henkilöiden muodostama yhteenliittymä ja jolla on yhteinen tavoite ja tarkoituksenmukainen rakenne"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fi",
    "@value" : "Organisaatio"
  }, {
    "@language" : "sv",
    "@value" : "Organisation"
  }, {
    "@language" : "en",
    "@value" : "Organization"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/ns/org#Organization"
  } ],
  "http://www.w3.org/2004/02/skos/core#broadMatch" : [ {
    "@id" : "http://data.europa.eu/m8g/PublicOrganisation"
  } ],
  "http://www.w3.org/2004/02/skos/core#closeMatch" : [ {
    "@id" : "http://xmlns.com/foaf/0.1/Organization"
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://iri.suomi.fi/model/suomiptv2/Organization"
  }, {
    "@id" : "http://schema.org/Organization"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fi",
    "@value" : "Organisaatio"
  }, {
    "@language" : "sv",
    "@value" : "Organisation"
  }, {
    "@language" : "en",
    "@value" : "Organization"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "KELAO-kontekstissa vastaa PTV:n Organization-käsitettä ja \n         schema.org/Organization-käsitettä. Käytetään kuvaamaan kaikkia \n         toimijaorganisaatioita sektorirajat ylittäen (julkinen, yksityinen, \n         kolmas sektori). EU Core Public Organisation on tämän erikoistapaus."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Region",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A region (maakunta): an areal unit of regional development and planning composed of municipalities."
  }, {
    "@language" : "fi",
    "@value" : "Maakunta. Kuntien muodostama alueellisen kehittämisen ja suunnittelun yksikkö."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "sv",
    "@value" : "Landskap"
  }, {
    "@language" : "fi",
    "@value" : "Maakunta"
  }, {
    "@language" : "en",
    "@value" : "Region"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://kela.fi/ontology/kelao#Location"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "sv",
    "@value" : "Landskap"
  }, {
    "@language" : "fi",
    "@value" : "Maakunta"
  }, {
    "@language" : "en",
    "@value" : "Region"
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#Service",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A social-security-related service, e.g. an application or advisory service."
  }, {
    "@language" : "fi",
    "@value" : "Sosiaaliturvaan liittyvä palvelu, esim. hakemus- tai neuvontapalvelu."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fi",
    "@value" : "Palvelu"
  }, {
    "@language" : "en",
    "@value" : "Service"
  }, {
    "@language" : "sv",
    "@value" : "Tjänst"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://purl.org/vocab/cpsv#PublicService"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "An activity by which a service provider responds to a customer's need."
  }, {
    "@language" : "fi",
    "@value" : "Toiminto, jolla palveluntoteuttaja vastaa asiakkaan tarpeeseen."
  } ],
  "http://www.w3.org/2004/02/skos/core#exactMatch" : [ {
    "@id" : "http://iri.suomi.fi/model/suomiptv2/Service"
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fi",
    "@value" : "Palvelu"
  }, {
    "@language" : "en",
    "@value" : "Service"
  }, {
    "@language" : "sv",
    "@value" : "Tjänst"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "en",
    "@value" : "In the core model a service is linked to a benefit (kelao:relatedService) and is accessible through service channels (kelao:hasServiceChannel). Service channels (kelao:ServiceChannel) and service units (kelao:ServiceUnit) are part of the core model; broader PTV metadata (e.g. funding type, service classification, target groups) remains outside it."
  }, {
    "@language" : "fi",
    "@value" : "Ydinmallissa palvelu liitetään etuuteen (kelao:relatedService) ja se on käytettävissä palvelukanavien kautta (kelao:hasServiceChannel). Palvelukanava (kelao:ServiceChannel) ja palveluyksikkö (kelao:ServiceUnit) kuuluvat ydinmalliin; laajempi PTV-metatieto (esim. rahoitustyyppi, palveluluokitus, kohderyhmät) jää edelleen ydinmallin ulkopuolelle."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#ServiceChannel",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A service channel: the way a customer accesses a service, e.g. e-service, web page, printable form, telephone service or a physical service point. A single service may have several alternative or sequential channels."
  }, {
    "@language" : "fi",
    "@value" : "Palvelu- tai asiointikanava: tapa, jolla asiakas saa palvelun käyttöönsä. Kanava voi olla esimerkiksi verkkoasiointi, verkkosivu, tulostettava lomake, puhelinasiointi tai fyysinen palvelupaikka. Yhdellä palvelulla voi olla useita vaihtoehtoisia tai peräkkäisiä kanavia."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fi",
    "@value" : "Palvelukanava"
  }, {
    "@language" : "en",
    "@value" : "Service Channel"
  }, {
    "@language" : "sv",
    "@value" : "Servicekanal"
  } ],
  "http://www.w3.org/2004/02/skos/core#closeMatch" : [ {
    "@id" : "http://iri.suomi.fi/model/suomiptv2/ServiceChannel"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "fi",
    "@value" : "Tapa, jolla asiakas saa palvelun käyttöönsä."
  }, {
    "@language" : "en",
    "@value" : "The way in which a customer accesses a service."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fi",
    "@value" : "Palvelukanava"
  }, {
    "@language" : "en",
    "@value" : "Service Channel"
  }, {
    "@language" : "sv",
    "@value" : "Servicekanal"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Linkitetty PTV:n ServiceChannel-käsitteeseen vain skos:closeMatch-suhteella, koska ptv: on epävakaa nimiavaruus."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#ServiceUnit",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A service unit (service point) with a physical location. Service unit data has been combined from Kela's internal sources and PTV service-channel data (entity matching)."
  }, {
    "@language" : "fi",
    "@value" : "Palveluyksikkö eli palvelupiste, jolla on fyysinen sijainti. Palveluyksiköiden tiedot on yhdistetty Kelan sisäisistä lähteistä ja PTV:n palvelukanavatiedoista (entity matching)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "https://kela.fi/ontology/kelao"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "fi",
    "@value" : "Palveluyksikkö"
  }, {
    "@language" : "en",
    "@value" : "Service Unit"
  }, {
    "@language" : "sv",
    "@value" : "Serviceenhet"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "https://kela.fi/ontology/kelao#ServiceChannel"
  } ],
  "http://www.w3.org/2004/02/skos/core#altLabel" : [ {
    "@language" : "fi",
    "@value" : "Palvelupiste"
  } ],
  "http://www.w3.org/2004/02/skos/core#closeMatch" : [ {
    "@id" : "http://iri.suomi.fi/model/suomiptv2/ServiceChannel"
  } ],
  "http://www.w3.org/2004/02/skos/core#definition" : [ {
    "@language" : "en",
    "@value" : "A physically located service point at which a service is provided."
  }, {
    "@language" : "fi",
    "@value" : "Fyysisesti sijaitseva palvelupiste, jossa palvelua tarjotaan."
  } ],
  "http://www.w3.org/2004/02/skos/core#prefLabel" : [ {
    "@language" : "fi",
    "@value" : "Palveluyksikkö"
  }, {
    "@language" : "en",
    "@value" : "Service Unit"
  }, {
    "@language" : "sv",
    "@value" : "Serviceenhet"
  } ],
  "http://www.w3.org/2004/02/skos/core#scopeNote" : [ {
    "@language" : "fi",
    "@value" : "Palvelupiste on palvelukanavan erikoistapaus, siksi rdfs:subClassOf kelao:ServiceChannel."
  } ]
}, {
  "@id" : "https://kela.fi/ontology/kelao#StandaloneBenefit",
