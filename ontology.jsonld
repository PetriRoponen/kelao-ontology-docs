}, {
  "@id" : "https://kela.fi/ontology/kelao",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/abstract" : [ {
    "@language" : "fi",
    "@value" : "Sosiaaliturvan ydinontologia kuvaa etuudet, etuuskriteerit, palvelut,  \n        organisaatiot, maantieteelliset alueet, palvelukanavat, tietotuotteet, lainsäädännön sekä sosiaaliturvan käsitteet.\n        "
  }, {
    "@language" : "en",
    "@value" : "The Social Security Core Ontology describes the conceptual structure of the Finnish social security system.\n\t\tIt is intended to support knowledge graph implementations for policy analysis, eligibility reasoning and data integration. The ontology models relationships between:\n        benefits, eligibility criteria, services (benefit related), life situations, organisations, legislation, and concepts.\n"
  } ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@id" : "https://www.linkedin.com/in/petri-roponen-052aa772"
  } ],
  "http://purl.org/dc/terms/created" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-06-08"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Petri Roponen"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "Core Ontology for Finnish social security concepts: applicants, benefits, eligibility criteria, services, organisations and legislation."
  }, {
    "@language" : "en",
    "@value" : "This is a draft version. Content is subject to change."
  }, {
    "@language" : "fi",
    "@value" : "Tämä on luonnosversio (Draft). Sisältö voi muuttua."
  }, {
    "@language" : "fi",
    "@value" : "Ydinontologia Suomen sosiaaliturvan keskeisille käsitteille: hakijat, etuudet, etuuskriteerit, palvelut, organisaatiot ja säädökset."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/modified" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#date",
    "@value" : "2026-06-17"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@language" : "en",
    "@value" : "Finnish Social Security Core Ontology"
  }, {
    "@language" : "fi",
    "@value" : "Sosiaaliturvan ydinontologia"
  } ],
  "http://purl.org/vocab/vann/preferredNamespacePrefix" : [ {
    "@value" : "kelao"
  } ],
  "http://purl.org/vocab/vann/preferredNamespaceUri" : [ {
    "@type" : "http://www.w3.org/2001/XMLSchema#anyURI",
    "@value" : "https://kela.fi/ontology/kelao#"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "fi",
    "@value" : "Ydinversio sisältää vain sosiaaliturvan keskeiset käsitteet (etuudet, kelpoisuus, elämäntilanteet, säädökset, ...)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Finnish Social Security Core Ontology"
  }, {
    "@language" : "fi",
    "@value" : "Sosiaaliturvan ydinontologia"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#seeAlso" : [ {
    "@id" : "http://data.europa.eu/eli/ontology#"
  }, {
    "@id" : "http://data.europa.eu/m8g/"
  }, {
    "@id" : "http://iri.suomi.fi/model/suomiptv2/"
  }, {
    "@id" : "http://purl.org/dc/terms/"
  }, {
    "@id" : "http://purl.org/vocab/cpsv#"
  }, {
    "@id" : "http://schema.org/"
  }, {
    "@id" : "http://www.w3.org/2003/01/geo/wgs84_pos#"
  }, {
    "@id" : "http://www.w3.org/ns/locn#"
  }, {
    "@id" : "http://www.w3.org/ns/org#"
  }, {
    "@id" : "http://www.w3.org/ns/prov#"
  }, {
    "@id" : "http://www.w3.org/ns/shacl#"
  }, {
    "@id" : "https://semiceu.github.io/CPSV-AP/releases/3.2.0/"
