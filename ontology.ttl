###  https://kela.fi/ontology/kelao#partText
:partText rdf:type owl:DatatypeProperty ;
          rdfs:range xsd:string ;
          rdfs:comment "Lainosan esim. pykälän teksti"@fi ,
                       "Part text of the statute"@en ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "lainosan teksti"@fi ,
                     "part text"@en ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "lainosan teksti"@fi ,
                                                          "part text"@en .


###  https://kela.fi/ontology/kelao#partType
:partType rdf:type owl:DatatypeProperty ;
          rdfs:range xsd:string ;
          rdfs:comment "Esim. 'luku', 'pykälä', 'momentti', 'kohta'"@fi ,
                       "Part type"@en ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "osan tyyppi"@fi ,
                     "part type"@en ;
          <http://www.w3.org/2004/02/skos/core#example> "momentti"@fi ,
                                                        "pykälä"@fi ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "osan tyyppi"@fi ,
                                                          "part type"@en .


###  https://kela.fi/ontology/kelao#processingTime
:processingTime rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:duration ;
                rdfs:comment "Etuuden keskimääräinen käsittelyaika päivinä hakemuksen saapumisesta. Joissain tapauksissa kyse on arkipäivistä esim. 5,1 arkipäivää."@fi ,
                             "Typical time required to process the benefit application."@en ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "handläggningstid"@sv ,
                           "käsittelyaika"@fi ,
                           "processing time"@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "handläggningstid"@sv ,
                                                                "käsittelyaika"@fi ,
                                                                "processing time"@en ;
                <http://www.w3.org/2004/02/skos/core#scopeNote> "xsd:duration ei kuulu OWL 2 DL -datatyyppikarttaan, mutta on tuettu kaikissa KELAO-kohdejärjestelmissä (GraphDB, Fuseki)."@fi .


###  https://kela.fi/ontology/kelao#processingTimeBusinessDays
:processingTimeBusinessDays rdf:type owl:DatatypeProperty ;
                            rdfs:range xsd:duration ;
                            rdfs:comment "Käsittelyaika arkipäivinä (maanantai–perjantai, pois lukien pyhäpäivät)."@fi ,
                                         "Processing time in business days (Monday-Friday, excluding holidays). Decimal values allowed (e.g., 5.1 = 5 days and 0.8 hours)."@en ;
                            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                            rdfs:label "käsittelyaika arkipäivinä"@fi ,
                                       "processing time in business days"@en ;
                            <http://www.w3.org/2004/02/skos/core#prefLabel> "käsittelyaika arkipäivinä"@fi ,
                                                                            "processing time in business days"@en ;
                            <http://www.w3.org/2004/02/skos/core#scopeNote> "xsd:duration ei kuulu OWL 2 DL -datatyyppikarttaan, mutta on tuettu kaikissa KELAO-kohdejärjestelmissä (GraphDB, Fuseki)."@fi .


###  https://kela.fi/ontology/kelao#purpose
:purpose rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:string ;
         rdfs:comment "Etuuden tarkoitus"@fi ,
                      "Syftet med förmånen"@sv ,
                      "The purpose of the benefit"@en ;
         rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
         rdfs:label "purpose"@en ,
                    "syftet med förmånen"@sv ,
                    "tarkoitus"@fi ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "purpose"@en ,
                                                         "syftet med förmånen"@sv ,
                                                         "tarkoitus"@fi .


###  https://kela.fi/ontology/kelao#recipientUnit
:recipientUnit rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:string ;
               rdfs:comment "Mottagande enhet"@sv ,
                            "Recipient unit"@en ,
                            "Saajayksikkö"@fi ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "mottagande enhet"@sv ,
                          "recipient unit"@en ,
                          "saajayksikkö"@fi ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "mottagande enhet"@sv ,
                                                               "recipient unit"@en ,
                                                               "saajayksikkö"@fi .


###  https://kela.fi/ontology/kelao#requiresEmploymentHistory
:requiresEmploymentHistory rdf:type owl:DatatypeProperty ;
                           rdfs:range xsd:boolean ;
                           rdfs:comment "Requires employment history"@en ,
                                        "Vaatii työhistorian"@fi ;
                           rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                           rdfs:label "requires employment history"@en ,
                                      "vaatii työhistorian"@fi ;
                           <http://www.w3.org/2004/02/skos/core#prefLabel> "requires employment history"@en ,
                                                                           "vaatii työhistorian"@fi .


###  https://kela.fi/ontology/kelao#residenceRequired
:residenceRequired rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:boolean ;
                   rdfs:comment "Residence required"@en ,
                                "Vaatii asumisen Suomessa"@fi ;
                   rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                   rdfs:label "residence required"@en ,
                              "vaatii asumisen Suomessa"@fi ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "residence required"@en ,
                                                                   "vaatii asumisen Suomessa"@fi .


###  https://kela.fi/ontology/kelao#taxable
:taxable rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:boolean ;
         rdfs:comment "Is the benefit taxable"@en ,
                      "Onko etuus verotettava vai ei"@fi ,
                      "Är förmånen skattepliktig"@sv ;
         rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
         rdfs:label "beskattningsbar"@sv ,
                    "taxable"@en ,
                    "verotettava"@fi ;
         <http://www.w3.org/2004/02/skos/core#note> "Tiedot löytyvät myös sivulta https://www.kela.fi/verotus"@fi ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "beskattningsbar"@sv ,
                                                         "taxable"@en ,
                                                         "verotettava"@fi .


###  https://kela.fi/ontology/kelao#uuid
:uuid rdf:type owl:DatatypeProperty ;
      rdfs:subPropertyOf <http://schema.org/identifier> ;
      rdfs:range xsd:string ;
      rdfs:comment "Universally unique identifier used for benefits and attachments."@en ,
                   "Yksilöllinen tunniste uuid. Käytössä etuuksilla, palvelukanavilla, palveluilla ja liitteissä."@fi ;
      rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
      rdfs:label "uuid"@en ,
                 "uuid"@fi ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "uuid"@en ,
                                                      "uuid"@fi .


###  https://kela.fi/ontology/kelao#validFrom
:validFrom rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:date ;
           rdfs:comment "Början av giltighet"@sv ,
                        "Etuuden voimassaolon alku, milloin Kela tai muu organisaatio alkoi sitä maksamaan."@fi ,
                        "Start date of benefit validity"@en ;
           rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
           rdfs:label "början av giltighet"@sv ,
                      "valid from"@en ,
                      "voimassa alkaen"@fi ;
           <http://www.w3.org/2004/02/skos/core#exactMatch> <http://schema.org/startDate> ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "början av giltighet"@sv ,
                                                           "valid from"@en ,
                                                           "voimassa alkaen"@fi .


###  https://kela.fi/ontology/kelao#validTo
:validTo rdf:type owl:DatatypeProperty ;
         rdfs:range xsd:date ;
         rdfs:comment "End date of benefit validity"@en ,
                      "Etuuden voimassaolon loppu"@fi ,
                      "Förmånen gäller till och med datumet"@sv ;
         rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
         rdfs:label "tills giltigt"@sv ,
                    "valid to"@en ,
                    "voimassa asti"@fi ;
         <http://www.w3.org/2004/02/skos/core#exactMatch> <http://schema.org/endDate> ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "tills giltigt"@sv ,
                                                         "valid to"@en ,
                                                         "voimassa asti"@fi .


###  https://kela.fi/ontology/kelao#versionDate
:versionDate rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf <http://data.europa.eu/eli/ontology#version_date> ;
             rdfs:range xsd:date ;
             rdfs:comment "Päivämäärä, jolloin säädöksen tämä versio on voimassa."@fi ,
                          "The point-in-time at which the provided description of the legislation is valid."@en ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "versiointipäivä"@fi ,
                        "version date"@en ;
             <http://www.w3.org/2004/02/skos/core#exactMatch> <http://schema.org/legislationDateVersion> ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "versiointipäivä"@fi ,
                                                             "version date"@en ;
             <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:LegalResource-instansseilla. Kuvaa hetken, jolloin säädöksen kyseinen versio on voimassa."@fi .


