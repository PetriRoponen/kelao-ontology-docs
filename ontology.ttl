<http://purl.org/vocab/cpsv#PublicService> rdf:type owl:Class .


###  http://schema.org/DigitalDocument
<http://schema.org/DigitalDocument> rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  http://www.w3.org/ns/org#Organization
<http://www.w3.org/ns/org#Organization> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Agent
<http://www.w3.org/ns/prov#Agent> rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
<http://www.w3.org/ns/prov#Entity> rdf:type owl:Class .


###  https://kela.fi/ontology/kelao#Appeal
:Appeal rdf:type owl:Class ;
        rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> .


###  https://kela.fi/ontology/kelao#Applicant
:Applicant rdf:type owl:Class ;
           rdfs:subClassOf <http://www.w3.org/ns/prov#Agent> ;
           rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
           rdfs:label "Applicant"@en ,
                      "Hakija"@fi ,
                      "Sökande"@sv ;
           <http://www.w3.org/2004/02/skos/core#definition> "A natural or legal person who applies for a benefit or service, or to whom the right to apply has been transferred."@en ,
                                                            "Henkilö tai oikeushenkilö, joka hakee etuutta tai palvelua, tai jolle hakuoikeus on siirtynyt."@fi ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "Applicant"@en ,
                                                           "Hakija"@fi ,
                                                           "Sökande"@sv ;
           <http://www.w3.org/2004/02/skos/core#scopeNote> "Hakija on prosessirooli. kelao:User on sovelluksen käyttäjä; sama henkilö voi olla molempia."@fi .


###  https://kela.fi/ontology/kelao#Application
:Application rdf:type owl:Class ;
             rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "Ansökan"@sv ,
                        "Application"@en ,
                        "Hakemus"@fi ;
             <http://www.w3.org/2004/02/skos/core#definition> "An applicant's request for a benefit or service. Filing initiates processing of the case."@en ,
                                                              "Hakijan etuutta tai palvelua koskeva hakemus. Hakemuksen vireilletulo käynnistää asian käsittelyn."@fi ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Ansökan"@sv ,
                                                             "Application"@en ,
                                                             "Hakemus"@fi ;
             <http://www.w3.org/2004/02/skos/core#scopeNote> "Conceptual class only. The KELAO knowledge graph does not contain applicant-level instances — personal data is processed in Kela's operational systems."@en ,
                                                             "Käsitteellinen luokka. KELAO-tietämysgraafi ei sisällä hakijakohtaisia instansseja — henkilötiedot käsitellään Kelan operatiivisissa järjestelmissä."@fi .


###  https://kela.fi/ontology/kelao#Attachment
:Attachment rdf:type owl:Class ;
            rdfs:subClassOf <http://schema.org/DigitalDocument> ;
            rdfs:comment "An application attachment, e.g. a receipt, certificate or form."@en ,
                         "Hakemuksen liite, esim. tosite, todistus tai lomake."@fi ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "Attachment"@en ,
                       "Bilaga"@sv ,
                       "Liite"@fi ;
            <http://www.w3.org/2004/02/skos/core#definition> "Hakemukseen liitettävä lisämateriaali, joka täydentää tai todentaa hakemuksen tietoja."@fi ,
                                                             "Supplementary material attached to an application that completes or substantiates the application's information."@en ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "Attachment"@en ,
                                                            "Bilaga"@sv ,
                                                            "Liite"@fi ;
            <http://www.w3.org/2004/02/skos/core#scopeNote> "Liitettä tarvitaan joskus hakemuksen liitteeksi; pakollisuus on hakemus- tai etuuskohtaista (kuvataan SHACLissa, ei luokkatasolla)."@fi .


###  https://kela.fi/ontology/kelao#Benefit
:Benefit rdf:type owl:Class ;
         rdfs:subClassOf <http://purl.org/vocab/cpsv#PublicService> .


###  https://kela.fi/ontology/kelao#BenefitComponent
:BenefitComponent rdf:type owl:Class ;
                  rdfs:subClassOf :Benefit ;
                  owl:disjointWith :StandaloneBenefit .


###  https://kela.fi/ontology/kelao#BenefitGroup
:BenefitGroup rdf:type owl:Class ;
              rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
              rdfs:comment "Benefit group"@en ,
                           "Kelan etuusryhmitys"@fi ;
              rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
              rdfs:label "Benefit Group"@en ,
                         "Etuusryhmä"@fi ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "Benefit Group"@en ,
                                                              "Etuusryhmä"@fi .


###  https://kela.fi/ontology/kelao#Decision
:Decision rdf:type owl:Class ;
          rdfs:subClassOf <http://www.w3.org/ns/prov#Entity> ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "Beslut"@sv ,
                     "Decision"@en ,
                     "Päätös"@fi ;
          <http://www.w3.org/2004/02/skos/core#definition> "An authority's resolution on an application; grants or rejects the requested benefit in full or in part."@en ,
                                                           "Viranomaisen ratkaisu hakemukseen; myöntää tai hylkää haetun etuuden kokonaan tai osittain."@fi ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "Beslut"@sv ,
                                                          "Decision"@en ,
                                                          "Päätös"@fi .


###  https://kela.fi/ontology/kelao#LegalResource
:LegalResource rdf:type owl:Class ;
               rdfs:subClassOf <http://data.europa.eu/eli/ontology#LegalResource> ;
               rdfs:comment "A work in a legislative corpus. This applies to acts that have been legally enacted (whether or not they are still in force). A legal resource can represent a legal act or any component of a legal act, like an article. Legal resources can be linked together using properties defined in the model."@en ,
                            "Lainsäädäntöaineistoon kuuluva teos. Tämä koskee lainvoimaisesti säädettyjä lakeja (riippumatta siitä, ovatko ne vielä voimassa). Oikeudellinen resurssi voi edustaa säädöstä tai mitä tahansa säädöksen osaa, kuten artiklaa. Oikeudelliset resurssit voidaan linkittää toisiinsa mallissa määriteltyjen ominaisuuksien avulla."@fi ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "Juridisk resurs"@sv ,
                          "Legal Resource"@en ,
                          "Säädös"@fi ;
               <http://www.w3.org/2004/02/skos/core#definition> "Tekstikokonaisuus, joka sisältää julkisen vallan antamia yleisesti noudatettaviksi tarkoitettuja säännöksiä."@fi ,
                                                                "Text containing provisions issued by public authorities that are to be observed generally."@en ;
               <http://www.w3.org/2004/02/skos/core#exactMatch> <http://schema.org/Legislation> ;
               <http://www.w3.org/2004/02/skos/core#example> "Examples of statutes are acts and decrees as well as legal provisions issued by authorities."@en ,
                                                             "Säädöksiä ovat esimerkiksi lait ja asetukset sekä viranomaisten antamat oikeussäännöt."@fi .


###  https://kela.fi/ontology/kelao#LegalResourcePart
:LegalResourcePart rdf:type owl:Class ;
                   rdfs:subClassOf <http://data.europa.eu/eli/ontology#LegalResource> ;
                   rdfs:comment """Lain tai asetuksen osa (luku, pykälä, momentti, kohta yms.).
          Tämä luokka on tarkoitettu erottamaan kokonaiset lait niiden osista. EU-asetuksissa ym. on myös muu jaottelu kuin Suomessa."""@fi ,
                                "Legal Resource Part"@en ,
                                "Osa laista riippumatta siitä, onko kyseessä luku, pykälä vai momentti."@fi ;
                   rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                   rdfs:label "Lagdel"@sv ,
                              "Lain osa"@fi ,
                              "Legal Resource Part"@en ;
                   <http://www.w3.org/2004/02/skos/core#definition> "Lain tai asetuksen osa riippumatta siitä, onko kyseessä luku, pykälä vai momentti"@fi ;
                   <http://www.w3.org/2004/02/skos/core#example> "Kansaneläkelain 23 §"@fi ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "Lagdel"@sv ,
                                                                   "Lain osa"@fi ,
                                                                   "Legal Resource Part"@en .


###  https://kela.fi/ontology/kelao#LifeSituationClassification
:LifeSituationClassification rdf:type owl:Class ;
                             rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
                             rdfs:comment """Elämäntilanteilla tarkoitetaan sellaisia muutosvaiheita, joita kuvaa väliaikaisuus, erityisten palvelujen ja tiedon tarve sekä niihin kohdennetut palvelut.
        Elämäntilanneluokitus on toteutettu muualla skos-luokituksena. Luokituksen luokat ovat käsitteitä. Luokitus on luonnos. Pohjana on käytetty
        DVV:n elämäntapahtumaluokitusta, joka perustuu EU-luokitukseen."""@fi ,
                                          "Life situations refer to phases of change characterized by temporary nature, the need for special services and information, and services targeted to them."@en ;
                             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                             rdfs:label "ElämäntilanneLuokitus"@fi ,
                                        "Klassificering av livssituationer"@sv ,
                                        "Life Situation Classification"@en ;
                             <http://www.w3.org/2004/02/skos/core#closeMatch> <http://iri.suomi.fi/model/suomiptv2/LifeEventClassification> ;
                             <http://www.w3.org/2004/02/skos/core#definition> "Elämäntilanteilla tarkoitetaan sellaisia muutosvaiheita, joita kuvaa väliaikaisuus, erityisten palvelujen ja tiedon tarve sekä niihin kohdennetut palvelut."@fi ,
                                                                              "Life situations refer to phases of change characterized by temporary nature, the need for special services and information, and services targeted to them."@en ;
                             <http://www.w3.org/2004/02/skos/core#prefLabel> "ElämäntilanneLuokitus"@fi ,
                                                                             "Klassificering av livssituationer"@sv ,
                                                                             "Life Situation Classification"@en .


###  https://kela.fi/ontology/kelao#Organisation
:Organisation rdf:type owl:Class ;
              rdfs:subClassOf <http://www.w3.org/ns/org#Organization> ;
              rdfs:comment "An actor that is an association of individuals with a common goal and a purposeful structure"@en ,
                           "Toimija, joka on henkilöiden muodostama yhteenliittymä ja jolla on yhteinen tavoite ja tarkoituksenmukainen rakenne"@fi ;
              rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
              rdfs:label "Organisaatio"@fi ,
                         "Organisation"@sv ,
                         "Organization"@en ;
              <http://www.w3.org/2004/02/skos/core#broadMatch> <http://data.europa.eu/m8g/PublicOrganisation> ;
              <http://www.w3.org/2004/02/skos/core#closeMatch> <http://xmlns.com/foaf/0.1/Organization> ;
              <http://www.w3.org/2004/02/skos/core#exactMatch> <http://iri.suomi.fi/model/suomiptv2/Organization> ,
                                                               <http://schema.org/Organization> ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "Organisaatio"@fi ,
                                                              "Organisation"@sv ,
                                                              "Organization"@en ;
              <http://www.w3.org/2004/02/skos/core#scopeNote> """KELAO-kontekstissa vastaa PTV:n Organization-käsitettä ja 
         schema.org/Organization-käsitettä. Käytetään kuvaamaan kaikkia 
         toimijaorganisaatioita sektorirajat ylittäen (julkinen, yksityinen, 
         kolmas sektori). EU Core Public Organisation on tämän erikoistapaus."""@fi .


###  https://kela.fi/ontology/kelao#Service
:Service rdf:type owl:Class ;
         rdfs:subClassOf <http://purl.org/vocab/cpsv#PublicService> ;
         rdfs:comment "A social-security-related service, e.g. an application or advisory service."@en ,
                      "Sosiaaliturvaan liittyvä palvelu, esim. hakemus- tai neuvontapalvelu."@fi ;
         rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
         rdfs:label "Palvelu"@fi ,
                    "Service"@en ,
                    "Tjänst"@sv ;
         <http://www.w3.org/2004/02/skos/core#definition> "An activity by which a service provider responds to a customer's need."@en ,
                                                          "Toiminto, jolla palveluntoteuttaja vastaa asiakkaan tarpeeseen."@fi ;
         <http://www.w3.org/2004/02/skos/core#exactMatch> <http://iri.suomi.fi/model/suomiptv2/Service> ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "Palvelu"@fi ,
                                                         "Service"@en ,
                                                         "Tjänst"@sv ;
         <http://www.w3.org/2004/02/skos/core#scopeNote> "Ydinmallissa palvelu liitetään etuuteen esim. hakemus- tai neuvontapalveluna (kelao:relatedService). Palvelukanavat ja PTV-metatieto ovat ydinmallin ulkopuolella."@fi .


###  https://kela.fi/ontology/kelao#StandaloneBenefit
:StandaloneBenefit rdf:type owl:Class ;
                   rdfs:subClassOf :Benefit ;
                   rdfs:comment "Kokonainen, itsenäinen etuus."@fi ;
                   rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                   rdfs:label "Itsenäinen etuus"@fi ,
                              "Standalone Benefit"@en ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "Itsenäinen etuus"@fi ,
                                                                   "Standalone Benefit"@en .


###  https://kela.fi/ontology/kelao#StatuteType
:StatuteType rdf:type owl:Class ;
             rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
             rdfs:comment "Statute type classification (draft)"@en ,
                          "Säädöksen tyyppi määritellään skos-luokituksessa StatuteTypeSkos. Luokitus on luonnos. Sisältää Kelaan soveltuvan sekä suomalaisen että eu-lainsäädännön"@fi ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "Författningstyp"@sv ,
                        "Statute Type"@en ,
                        "Säädöstyyppi"@fi ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Författningstyp"@sv ,
                                                             "Statute Type"@en ,
                                                             "Säädöstyyppi"@fi .


###  https://kela.fi/ontology/kelao#User
:User rdf:type owl:Class ;
      rdfs:subClassOf <http://www.w3.org/ns/prov#Agent> ;
      rdfs:comment "Application user, user."@en ,
                   "Sovelluksen käyttäjä, esim. verkkosovelluksen käyttäjä."@fi ;
      rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
      rdfs:label "Användare"@sv ,
                 "Käyttäjä"@fi ,
                 "User"@en ;
      <http://www.w3.org/2004/02/skos/core#definition> "A human actor or agent, user or application user"@en ,
                                                       "Sovelluksen käyttäjä, agentti tms."@fi ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Användare"@sv ,
                                                      "Käyttäjä"@fi ,
                                                      "User"@en .


