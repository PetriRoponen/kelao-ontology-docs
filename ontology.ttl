@prefix : <https://kela.fi/ontology/kelao#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://kela.fi/ontology/kelao#> .

<https://kela.fi/ontology/kelao> rdf:type owl:Ontology ;
                                  owl:versionIRI <https://petriroponen.github.io/kelao-ontology-docs/> ;
                                  <http://purl.org/dc/terms/abstract> """Sosiaaliturvan ydinontologia kuvaa etuudet, etuuskriteerit, palvelut,  
        organisaatiot, maantieteelliset alueet, palvelukanavat, tietotuotteet, lainsäädännön sekä sosiaaliturvan käsitteet.
        """@fi ,
                                                                      """The Social Security Core Ontology describes the conceptual structure of the Finnish social security system.
	It is intended to support knowledge graph implementations for policy analysis, eligibility reasoning and data integration. The ontology models relationships between:
        benefits, eligibility criteria, services, life situations, organisations, legislation, and concepts.
"""@en ;
                                  <http://purl.org/dc/terms/contributor> <https://www.linkedin.com/in/petri-roponen-052aa772> ;
                                  <http://purl.org/dc/terms/created> "2026-06-08"^^xsd:date ;
                                  <http://purl.org/dc/terms/creator> "Petri Roponen" ;
                                  <http://purl.org/dc/terms/description> "Core Ontology for Finnish social security concepts: applicants, benefits, eligibility criteria, services, organisations and legislation."@en ,
                                                                         "This is a draft version. Content is subject to change."@en ,
                                                                         "Tämä on luonnosversio (Draft). Sisältö voi muuttua."@fi ,
                                                                         "Ydinontologia Suomen sosiaaliturvan keskeisille käsitteille: hakijat, etuudet, etuuskriteerit, palvelut, organisaatiot ja säädökset."@fi ;
                                  <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                  <http://purl.org/dc/terms/modified> "2026-06-17"^^xsd:date ;
                                  <http://purl.org/dc/terms/title> "Finnish Social Security Core Ontology"@en ,
                                                                   "Sosiaaliturvan ydinontologia"@fi ;
                                  <http://purl.org/vocab/vann/preferredNamespacePrefix> "kelao" ;
                                  <http://purl.org/vocab/vann/preferredNamespaceUri> "https://kela.fi/ontology/kelao#"^^xsd:anyURI ;
                                  rdfs:comment "Ydinversio sisältää vain sosiaaliturvan keskeiset käsitteet (etuudet, kelpoisuus, elämäntilanteet, säädökset, ...)."@fi ;
                                  rdfs:label "Finnish Social Security Core Ontology"@en ,
                                             "Sosiaaliturvan ydinontologia"@fi ;
                                  rdfs:seeAlso <http://data.europa.eu/eli/ontology#> ,
                                               <http://data.europa.eu/m8g/> ,
                                               <http://iri.suomi.fi/model/suomiptv2/> ,
                                               <http://purl.org/dc/terms/> ,
                                               <http://purl.org/vocab/cpsv#> ,
                                               <http://schema.org/> ,
                                               <http://www.w3.org/2003/01/geo/wgs84_pos#> ,
                                               <http://www.w3.org/ns/locn#> ,
                                               <http://www.w3.org/ns/org#> ,
                                               <http://www.w3.org/ns/prov#> ,
                                               <http://www.w3.org/ns/shacl#> ,
                                               <https://semiceu.github.io/CPSV-AP/releases/3.2.0/> ;
                                  owl:priorVersion "0.2.0-core-draft" ;
                                  owl:versionInfo "0.3.0-core-draft" ;
                                  <http://www.w3.org/2004/02/skos/core#changeNote> "0.3.0: lisätty maantieteelliset alueet (Location, Municipality, WellbeingServiceCounty, Region, Country), palvelukanava (ServiceChannel) ja palveluyksikkö (ServiceUnit) sekä tietotuote (DataProduct) relaatioineen ja ominaisuuksineen."@fi ,
                                                                                   "Automated document generation"@en ,
                                                                                   "Automatisoitu dokumentaation luonti .ttl-tiedostosta"@fi ;
                                  <http://www.w3.org/2004/02/skos/core#scopeNote> "Sosiaaliturvan tietämysgraafi (KELAO) ei sisällä hakijakohtaisia tietoja — henkilötiedot käsitellään Kelan operatiivisissa järjestelmissä."@fi ,
                                                                                  "The Social Security knowledge graph (KELAO) does not contain applicant-level data — personal data is processed in Kela's operational systems."@en .

