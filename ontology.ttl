###  https://kela.fi/ontology/kelao#hasApplication
:hasApplication rdf:type owl:ObjectProperty ;
                rdfs:domain :Applicant ;
                rdfs:range :Application ;
                rdfs:comment "An application submitted by the applicant."@en ,
                             "Hakijan jättämä hakemus."@fi ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "has application"@en ,
                           "jätti hakemuksen"@fi ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "has application"@en ,
                                                                "jätti hakemuksen"@fi .


###  https://kela.fi/ontology/kelao#hasAttachment
:hasAttachment rdf:type owl:ObjectProperty ;
               rdfs:domain :Application ;
               rdfs:range :Attachment ;
               rdfs:comment "An attachment belonging to the application."@en ,
                            "Hakemukseen liittyvä liite."@fi ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "hakemuksen liite"@fi ,
                          "has attachment"@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "hakemuksen liite"@fi ,
                                                               "has attachment"@en .


###  https://kela.fi/ontology/kelao#hasBenefitGroup
:hasBenefitGroup rdf:type owl:ObjectProperty ;
                 rdfs:domain :Benefit ;
                 rdfs:range :BenefitGroup ;
                 rdfs:comment "Etuusryhmä"@fi ,
                              "Has benefit group"@en ;
                 rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                 rdfs:label "etuusryhmä"@fi ,
                            "has benefit group"@en ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "etuusryhmä"@fi ,
                                                                 "has benefit group"@en .


###  https://kela.fi/ontology/kelao#hasBenefitPart
:hasBenefitPart rdf:type owl:ObjectProperty ;
                owl:inverseOf :isPartOfBenefit ;
                rdfs:domain :StandaloneBenefit ;
                rdfs:range :BenefitComponent ;
                rdfs:comment "Etuudella on osa"@fi ,
                             "Has benefit part"@en ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "etuudella on osa"@fi ,
                           "has benefit part"@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "etuudella on osa"@fi ,
                                                                "has benefit part"@en .


###  https://kela.fi/ontology/kelao#hasConcept
:hasConcept rdf:type owl:ObjectProperty ;
            rdfs:domain :Benefit ;
            rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
            rdfs:comment "Has concept"@en ,
                         "On käsite"@fi ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "has concept"@en ,
                       "on käsite"@fi ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "has concept"@en ,
                                                            "on käsite"@fi .


###  https://kela.fi/ontology/kelao#hasDecision
:hasDecision rdf:type owl:ObjectProperty ;
             rdfs:domain :Application ;
             rdfs:range :Decision ;
             rdfs:comment "Hakemukseen annettu päätös."@fi ,
                          "The decision issued on the application."@en ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "hakemuksen päätös"@fi ,
                        "has decision"@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "hakemuksen päätös"@fi ,
                                                             "has decision"@en .


###  https://kela.fi/ontology/kelao#hasGeographicArea
:hasGeographicArea rdf:type owl:ObjectProperty ;
                   rdfs:domain :ServiceUnit ;
                   rdfs:range :Location ;
                   rdfs:comment "Is located in"@en ,
                                "Palveluyksikkö sijaitsee tällä maantieteellisellä alueella."@fi ;
                   rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                   rdfs:label "is located in"@en ,
                              "sijaitsee alueella"@fi ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "is located in"@en ,
                                                                   "sijaitsee alueella"@fi .


###  https://kela.fi/ontology/kelao#hasProvider
:hasProvider rdf:type owl:ObjectProperty ;
             rdfs:domain :Benefit ;
             rdfs:range :Organisation ;
             rdfs:comment "Has provider"@en ,
                          "Vastuuorganisaatio"@fi ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "has provider"@en ,
                        "vastuuorganisaatio"@fi ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "has provider"@en ,
                                                             "vastuuorganisaatio"@fi .


###  https://kela.fi/ontology/kelao#hasServiceChannel
:hasServiceChannel rdf:type owl:ObjectProperty ;
                   rdfs:domain :Service ;
                   rdfs:range :ServiceChannel ;
                   rdfs:comment "A service has service channels. Services are accessible through service channels."@en ,
                                "Palvelulla on palvelukanava. Palvelu on käytettävissä palvelukanavien kautta."@fi ;
                   rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                   rdfs:label "has channel"@en ,
                              "kanava"@fi ;
                   <http://www.w3.org/2004/02/skos/core#closeMatch> <http://iri.suomi.fi/model/suomiptv2/hasServiceChannel> ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "has channel"@en ,
                                                                   "kanava"@fi .


###  https://kela.fi/ontology/kelao#hasServiceUnit
:hasServiceUnit rdf:type owl:ObjectProperty ;
                rdfs:domain :Organisation ;
                rdfs:range :ServiceUnit ;
                rdfs:comment "Has service unit"@en ,
                             "Organisaatiolla on palveluyksikkö."@fi ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "has service unit"@en ,
                           "on palveluyksikkö"@fi ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "has service unit"@en ,
                                                                "on palveluyksikkö"@fi .


###  https://kela.fi/ontology/kelao#has_part
:has_part rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf <http://data.europa.eu/eli/ontology#has_part> ,
                             <http://schema.org/hasPart> ;
          rdfs:domain :LegalResource ;
          rdfs:range :LegalResource ;
          rdfs:comment "Lain tai muun säädöksen osa esim. pykälä."@fi ,
                       "Statute has part"@en ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "has part"@en ,
                     "on osa säädöstä"@fi ,
                     "är del av"@sv ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "has part"@en ,
                                                          "on osa säädöstä"@fi ,
                                                          "är del av"@sv .


###  https://kela.fi/ontology/kelao#inhibiting
:inhibiting rdf:type owl:ObjectProperty ;
            rdfs:domain :Benefit ;
            rdfs:range :Benefit ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "estävä etuus"@fi ,
                       "hindrande förmån"@sv ,
                       "inhibiting benefit"@en ;
            rdfs:seeAlso <https://iri.suomi.fi/terminology/kela/c66> ;
            <http://www.w3.org/2004/02/skos/core#definition> "förmån som ska beaktas och på grund av vilken den förmånssökande inte beviljas en annan förmån"@sv ,
                                                             "huomioon otettava etuus, jonka vuoksi etuudenhakijalle ei myönnetä jotain toista etuutta"@fi ;
            <http://www.w3.org/2004/02/skos/core#exactMatch> <https://iri.suomi.fi/terminology/kela/c66> ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "estävä etuus"@fi ,
                                                            "hindrande förmån"@sv ,
                                                            "inhibiting benefit"@en ;
            :relationshipAbbreviation "EST" .


###  https://kela.fi/ontology/kelao#investigate
:investigate rdf:type owl:ObjectProperty ;
             rdfs:domain :Benefit ;
             rdfs:range :Benefit ;
             rdfs:comment "Benefit to investigate"@en ,
                          "Selvitä etuus"@fi ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "benefit to investigate"@en ,
                        "selvitä etuus"@fi ;
