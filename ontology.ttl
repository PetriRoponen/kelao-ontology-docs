                              "Standalone Benefit"@en ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "Itsenäinen etuus"@fi ,
                                                                   "Standalone Benefit"@en .


###  https://kela.fi/ontology/kelao#StatuteType
:StatuteType rdf:type owl:Class ;
             rdfs:subClassOf <http://www.w3.org/2004/02/skos/core#Concept> ;
             rdfs:comment "Statute type classification (draft). The Skos-classification has 13 classes for example EU regulation, Decree, Agreement, Government decree, and Presidential decree."@en ,
                          "Säädöksen tyyppi määritellään skos-luokituksessa StatuteType. Luokitus on luonnos. Sisältää Kelaan soveltuvan sekä suomalaisen että eu-lainsäädännön"@fi ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "Författningstyp"@sv ,
                        "Statute Type"@en ,
                        "Säädöstyyppi"@fi ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "Författningstyp"@sv ,
                                                             "Statute Type"@en ,
                                                             "Säädöstyyppi"@fi .


###  https://kela.fi/ontology/kelao#User
:User rdf:type owl:Class ;
      rdfs:subClassOf <http://www.w3.org/ns/prov#Agent> ;
      rdfs:comment "Application user, user."@en ,
                   "Sovelluksen käyttäjä, esim. verkkosovelluksen käyttäjä."@fi ;
      rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
      rdfs:label "Användare"@sv ,
                 "Käyttäjä"@fi ,
                 "User"@en ;
      <http://www.w3.org/2004/02/skos/core#definition> "A human actor or agent, user or application user"@en ,
                                                       "Sovelluksen käyttäjä, agentti tms."@fi ;
      <http://www.w3.org/2004/02/skos/core#prefLabel> "Användare"@sv ,
                                                      "Käyttäjä"@fi ,
                                                      "User"@en .


###  https://kela.fi/ontology/kelao#WellbeingServiceCounty
:WellbeingServiceCounty rdf:type owl:Class ;
                        rdfs:subClassOf :Location ;
                        rdfs:comment "A wellbeing services county: a self-governing area responsible for organising health, social and rescue services in Finland."@en ,
                                     "Hyvinvointialue. Suomen sosiaali- ja terveydenhuollon sekä pelastustoimen järjestämisestä vastaava itsehallinnollinen alue."@fi ;
                        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                        rdfs:label "Hyvinvointialue"@fi ,
                                   "Välfärdsområde"@sv ,
                                   "Wellbeing Service County"@en ;
                        <http://www.w3.org/2004/02/skos/core#prefLabel> "Hyvinvointialue"@fi ,
                                                                        "Välfärdsområde"@sv ,
                                                                        "Wellbeing Service County"@en .


