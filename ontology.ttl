                                                                "part identifier"@en .


###  https://kela.fi/ontology/kelao#partOrder
:partOrder rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:integer ;
           rdfs:comment "Osan järjestysnumero (esim. 1, 2, 3...)"@fi ,
                        "Part order of the statute"@en ;
           rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
           rdfs:label "järjestysnumero"@fi ,
                      "part order"@en ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "järjestysnumero"@fi ,
