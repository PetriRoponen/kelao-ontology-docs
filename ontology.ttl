###  https://kela.fi/ontology/kelao#relatedToLifeSituation
:relatedToLifeSituation rdf:type owl:ObjectProperty ;
                        owl:inverseOf :isLifeSituationFor ;
                        rdfs:domain :Benefit ;
                        rdfs:range :LifeSituationClassification ;
                        rdfs:comment "Liittyy elämäntilanteeseen"@fi ,
                                     "Related to life situation"@en ;
                        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                        rdfs:label "liittyy elämäntilanteeseen"@fi ,
                                   "related to life situation"@en ;
                        <http://www.w3.org/2004/02/skos/core#prefLabel> "liittyy elämäntilanteeseen"@fi ,
                                                                        "related to life situation"@en .


###  https://kela.fi/ontology/kelao#type_document
:type_document rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf <http://data.europa.eu/eli/ontology#type_document> ,
                                  <http://schema.org/legislationType> ;
               rdfs:domain :LegalResource ;
               rdfs:range :StatuteType ;
               rdfs:comment "Lain tai muun säädöksen tyyppi"@fi ,
                            "Statute type"@en ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "säädöksen tyyppi"@fi ,
                          "type"@sv ,
                          "type of document"@en ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "säädöksen tyyppi"@fi ,
                                                               "type"@sv ,
                                                               "type of document"@en .


#################################################################
#    Data properties
#################################################################

###  http://data.europa.eu/eli/ontology#date_document
<http://data.europa.eu/eli/ontology#date_document> rdf:type owl:DatatypeProperty .


###  http://data.europa.eu/eli/ontology#id_local
<http://data.europa.eu/eli/ontology#id_local> rdf:type owl:DatatypeProperty .


###  http://data.europa.eu/eli/ontology#version_date
<http://data.europa.eu/eli/ontology#version_date> rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:DatatypeProperty .


###  http://schema.org/amount
<http://schema.org/amount> rdf:type owl:DatatypeProperty .


###  http://schema.org/identifier
<http://schema.org/identifier> rdf:type owl:DatatypeProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
<http://www.w3.org/2004/02/skos/core#altLabel> rdf:type owl:DatatypeProperty .


###  https://kela.fi/ontology/kelao#abbreviation
:abbreviation rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:string ;
              rdfs:comment "Internal abbreviation used by Kela for the benefit."@en ,
                           "Kelan sisäisesti käyttämä etuuden lyhenne"@fi ;
              rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
              rdfs:label "abbreviation"@en ,
                         "lyhenne"@fi ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "abbreviation"@en ,
                                                              "lyhenne"@fi .


###  https://kela.fi/ontology/kelao#alternative
:alternative rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf <http://www.w3.org/2004/02/skos/core#altLabel> ;
             rdfs:range xsd:string ;
             rdfs:comment "An established acronym or alternative name for the legal resource."@en ,
                          "Säädöksen vakiintunut lyhenne tai vaihtoehtoinen nimi."@fi ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "lain lyhenne"@fi ,
                        "law acronym"@en ;
             <http://www.w3.org/2004/02/skos/core#exactMatch> <http://purl.org/dc/terms/alternative> ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "lain lyhenne"@fi ,
                                                             "law acronym"@en ;
             <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:LegalResource-instansseilla. Kuvaa säädöksen vakiintuneen lyhenteen, esim. 'KEL' tai 'SHL'."@fi .


###  https://kela.fi/ontology/kelao#amount
:amount rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf <http://schema.org/amount> ;
        rdfs:range xsd:string ;
        rdfs:comment "Rahallinen määrä."@fi ,
                     "The amount of money."@en ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "amount"@en ,
                   "määrä"@fi ;
        <http://www.w3.org/2004/02/skos/core#prefLabel> "amount"@en ,
                                                        "määrä"@fi .


###  https://kela.fi/ontology/kelao#appealDate
:appealDate rdf:type owl:DatatypeProperty ;
            rdfs:range xsd:date ;
            rdfs:comment "Date the appeal was filed."@en ,
                         "Päivä jolloin muutoksenhaku jätettiin."@fi ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "appeal date"@en ,
                       "muutoksenhaun päivä"@fi ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "appeal date"@en ,
                                                            "muutoksenhaun päivä"@fi ;
            <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:Appeal-instansseilla (xsd:date)."@fi .


###  https://kela.fi/ontology/kelao#applicationStatus
:applicationStatus rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Hakemuksen käsittelyvaiheen tila."@fi ,
                                "Processing status of the application."@en ;
                   rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                   rdfs:label "application status"@en ,
                              "hakemuksen tila"@fi ;
                   <http://www.w3.org/2004/02/skos/core#prefLabel> "application status"@en ,
                                                                   "hakemuksen tila"@fi ;
                   <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:Application-instansseilla. Esim. 'vireillä', 'käsittelyssä', 'ratkaistu'."@fi .


###  https://kela.fi/ontology/kelao#attachmentInOmaKela
:attachmentInOmaKela rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:boolean ;
                     rdfs:comment "Onko liite haettavissa tai ilmoitettavissa OmaKelassa."@fi ,
                                  "Whether the attachment can be requested or reported in OmaKela."@en ;
                     rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                     rdfs:label "is attachment in OmaKela"@en ,
                                "onko liite OmaKelassa"@fi ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "is attachment in OmaKela"@en ,
                                                                     "onko liite OmaKelassa"@fi ;
                     <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:Attachment-instansseilla (xsd:boolean)."@fi .


###  https://kela.fi/ontology/kelao#attachmentUri
:attachmentUri rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:anyURI ;
               rdfs:comment "URI link to where the attachment can be found."@en ,
                            "URI-linkki liitteeseen, josta liite löytyy."@fi ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "attachment uri"@en ,
                          "liitteen uri"@fi ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "attachment uri"@en ,
                                                               "liitteen uri"@fi ;
               <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:Attachment-instansseilla (xsd:anyURI)."@fi .


###  https://kela.fi/ontology/kelao#calculationBase
:calculationBase rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Calculation base"@en ,
                              "Laskentaperuste"@fi ;
                 rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                 rdfs:label "calculation base"@en ,
                            "laskentaperuste"@fi ;
                 <http://www.w3.org/2004/02/skos/core#definition> "Miten etuuden määrä lasketaan"@fi ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "calculation base"@en ,
                                                                 "laskentaperuste"@fi .


###  https://kela.fi/ontology/kelao#currentVersion
:currentVersion rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:anyURI ;
                rdfs:comment "Ajantasaisen lainosan URI"@fi ,
                             "Current version uri"@en ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "ajantasaisen lainosan URI"@fi ,
                           "current version uri"@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "ajantasaisen lainosan URI"@fi ,
                                                                "current version uri"@en .


###  https://kela.fi/ontology/kelao#date_document
:date_document rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf <http://data.europa.eu/eli/ontology#date_document> ;
               rdfs:range xsd:date ;
               rdfs:comment "Date of adoption or signature of the legal resource (yyyy-mm-dd)."@en ,
                            "Säädöksen hyväksymis- tai allekirjoituspäivä muodossa vvvv-kk-pp."@fi ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "date of document"@en ,
                          "säädöksen päiväys"@fi ;
               <http://www.w3.org/2004/02/skos/core#exactMatch> <http://schema.org/legislationDate> ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "date of document"@en ,
                                                               "säädöksen päiväys"@fi ;
               <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:LegalResource-instansseilla."@fi .


###  https://kela.fi/ontology/kelao#decisionDate
:decisionDate rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:date ;
              rdfs:comment "Date the decision was issued."@en ,
                           "Päivä jolloin päätös annettiin."@fi ;
              rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
              rdfs:label "decision date"@en ,
                         "päätöspäivä"@fi ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "decision date"@en ,
                                                              "päätöspäivä"@fi ;
              <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:Decision-instansseilla (xsd:date)."@fi .


###  https://kela.fi/ontology/kelao#decisionOutcome
:decisionOutcome rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Outcome of the decision."@en ,
                              "Päätöksen lopputulos."@fi ;
                 rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                 rdfs:label "decision outcome"@en ,
                            "päätöksen lopputulos"@fi ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "decision outcome"@en ,
                                                                 "päätöksen lopputulos"@fi ;
                 <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:Decision-instansseilla. Esim. 'myönnetty', 'hylätty', 'osittain myönnetty'."@fi .


###  https://kela.fi/ontology/kelao#filingDate
:filingDate rdf:type owl:DatatypeProperty ;
            rdfs:range xsd:date ;
            rdfs:comment "Date the application was filed and became pending."@en ,
                         "Hakemuksen vireilletulopäivä."@fi ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "filing date"@en ,
                       "vireilletulopäivä"@fi ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "filing date"@en ,
                                                            "vireilletulopäivä"@fi ;
            <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:Application-instansseilla (xsd:date). Päivä jolloin hakemus tuli vireille."@fi .


###  https://kela.fi/ontology/kelao#financing
:financing rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:string ;
           rdfs:comment "How the financing is organized"@en ,
                        "Hur finansieringen är organiserad"@sv ,
                        "Kuinka rahoitus on järjestetty"@fi ;
           rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
           rdfs:label "financing"@en ,
                      "financsieringen"@sv ,
                      "rahoitus"@fi ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "financing"@en ,
                                                           "financsieringen"@sv ,
                                                           "rahoitus"@fi .


###  https://kela.fi/ontology/kelao#homepage
:homepage rdf:type owl:DatatypeProperty ;
          rdfs:range xsd:anyURI ;
          rdfs:comment "Homepage"@en ,
                       "Kotisivu"@fi ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "homepage"@en ,
                     "kotisivu"@fi ;
          <http://www.w3.org/2004/02/skos/core#exactMatch> <http://iri.suomi.fi/model/suomiptv2/homePage> ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "homepage"@en ,
                                                          "kotisivu"@fi ;
          <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:Benefit-instansseilla etuuden kotisivuun viittaamisessa."@fi .


###  https://kela.fi/ontology/kelao#id_local
:id_local rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf <http://data.europa.eu/eli/ontology#id_local> ;
          rdfs:range xsd:string ;
          rdfs:comment "National identifier of the legal resource in the form number/year."@en ,
                       "Säädöksen kansallinen tunniste muodossa numero/vuosi."@fi ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "local identifier"@en ,
                     "paikallinen tunniste"@fi ;
          <http://www.w3.org/2004/02/skos/core#exactMatch> <http://schema.org/legislationIdentifier> ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "local identifier"@en ,
                                                          "paikallinen tunniste"@fi ;
          <http://www.w3.org/2004/02/skos/core#scopeNote> """Käytetään kelao:LegalResource-instansseilla. 
         Arvo on säädöksen kansallinen numero/vuosi-tunniste, 
         esim. '404/1948' tai '1301/2007'."""@fi .


###  https://kela.fi/ontology/kelao#identifier
:identifier rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf <http://purl.org/dc/terms/identifier> ;
            rdfs:range xsd:anyURI ;
            rdfs:comment "Official ELI URI identifying the legal resource on Finlex."@en ,
                         "Säädöksen virallinen ELI-URI Finlex-sivulle."@fi ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "identifier"@en ,
                       "tunniste"@fi ;
            <http://www.w3.org/2004/02/skos/core#exactMatch> <http://data.europa.eu/eli/ontology#eli> ,
                                                             <http://schema.org/identifier> ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "identifier"@en ,
                                                            "tunniste"@fi ;
            <http://www.w3.org/2004/02/skos/core#scopeNote> """Käytetään kelao:LegalResource-instansseilla. 
         Arvo on xsd:anyURI-muotoinen ELI-URI Finlex-palveluun, 
         esim. 'https://www.finlex.fi/fi/laki/ajantasa/2007/20071301'."""@fi .


###  https://kela.fi/ontology/kelao#indexLinked
:indexLinked rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:string ;
             rdfs:comment "Index linked"@en ,
                          "Mihin indeksiin etuus on sidottu (esim. Kansaneläkeindeksi)"@fi ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "indeksisidonnainen"@fi ,
                        "index linked"@en ;
             <http://www.w3.org/2004/02/skos/core#definition> "Mihin indeksiin etuus on sidottu (esim. Kansaneläkeindeksi)"@fi ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "indeksisidonnainen"@fi ,
                                                             "index linked"@en .


###  https://kela.fi/ontology/kelao#maximumAge
:maximumAge rdf:type owl:DatatypeProperty ;
            rdfs:range xsd:integer ;
            rdfs:comment "Maximum age limit"@en ,
                         "Yläikäraja"@fi ,
                         "Åldersgräns"@sv ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "maximum age"@en ,
                       "yläikäraja"@fi ,
                       "åldersgräns"@sv ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "maximum age"@en ,
                                                            "yläikäraja"@fi ,
                                                            "åldersgräns"@sv .


###  https://kela.fi/ontology/kelao#meansTest
:meansTest rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:string ;
           rdfs:comment "Determining entitlement to benefits requires a means test."@en ,
                        "Etuuden oikeuden päättely edellyttää tarveharkintaa, tarveharkinnan selitys."@fi ,
                        "För att fastställa rätten till förmåner krävs en behovsprövning."@sv ;
           rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
           rdfs:label "behovsbedömning"@sv ,
                      "means test"@en ,
                      "tarveharkinta"@fi ;
           <http://www.w3.org/2004/02/skos/core#prefLabel> "behovsbedömning"@sv ,
                                                           "means test"@en ,
                                                           "tarveharkinta"@fi .


###  https://kela.fi/ontology/kelao#minimumAge
:minimumAge rdf:type owl:DatatypeProperty ;
            rdfs:range xsd:integer ;
            rdfs:comment "Alaikäraja"@fi ,
                         "Minimum age limit"@en ,
                         "Åldersgräns"@sv ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "alaikäraja"@fi ,
                       "minimum age"@en ,
                       "åldersgräns"@sv ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "alaikäraja"@fi ,
                                                            "minimum age"@en ,
                                                            "åldersgräns"@sv .


###  https://kela.fi/ontology/kelao#partIdentifier
:partIdentifier rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:string ;
                rdfs:comment "Esim. '23' pykälälle, '1' momentille, 'a' kohdalle"@fi ,
                             "Part identifier"@en ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "osan tunniste"@fi ,
