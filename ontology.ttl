###  http://data.europa.eu/eli/ontology#date_document
<http://data.europa.eu/eli/ontology#date_document> rdf:type owl:DatatypeProperty .


###  http://data.europa.eu/eli/ontology#id_local
<http://data.europa.eu/eli/ontology#id_local> rdf:type owl:DatatypeProperty .


###  http://data.europa.eu/eli/ontology#version_date
<http://data.europa.eu/eli/ontology#version_date> rdf:type owl:DatatypeProperty .


###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:DatatypeProperty .


###  http://schema.org/amount
<http://schema.org/amount> rdf:type owl:DatatypeProperty .


###  http://schema.org/identifier
<http://schema.org/identifier> rdf:type owl:DatatypeProperty .


###  http://www.w3.org/2004/02/skos/core#notation
<http://www.w3.org/2004/02/skos/core#notation> rdf:type owl:DatatypeProperty ;
                                               rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                               rdfs:label "notation"@en ;
                                               <http://www.w3.org/2004/02/skos/core#definition> "A notation, also known as classification code, is a string of characters such as \"T58.5\" or \"303.4833\" used to uniquely identify a concept within the scope of a given concept scheme."@en ;
                                               <http://www.w3.org/2004/02/skos/core#scopeNote> "By convention, skos:notation is used with a typed literal in the object position of the triple."@en .


###  https://kela.fi/ontology/kelao#abbreviation
:abbreviation rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:string ;
              rdfs:comment "Internal abbreviation used by Kela for the benefit."@en ,
                           "Kelan sisäisesti käyttämä etuuden lyhenne"@fi ;
              rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
              rdfs:label "abbreviation"@en ,
                         "lyhenne"@fi ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "abbreviation"@en ,
                                                              "lyhenne"@fi .


###  https://kela.fi/ontology/kelao#alternative
:alternative rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:string .


###  https://kela.fi/ontology/kelao#amount
:amount rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf <http://schema.org/amount> ;
        rdfs:range xsd:string ;
        rdfs:comment "Rahallinen määrä."@fi ,
                     "The amount of money."@en ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "amount"@en ,
                   "määrä"@fi ;
        <http://www.w3.org/2004/02/skos/core#prefLabel> "amount"@en ,
                                                        "määrä"@fi .


