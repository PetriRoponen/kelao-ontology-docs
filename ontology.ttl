<http://schema.org/hasPart> rdf:type owl:ObjectProperty .


###  http://schema.org/legislationType
<http://schema.org/legislationType> rdf:type owl:ObjectProperty .


###  https://kela.fi/ontology/kelao#advancePayment
:advancePayment rdf:type owl:ObjectProperty ;
                rdfs:domain :Benefit ;
                rdfs:range :Benefit ;
                rdfs:comment "Advance payment"@en ,
                             "Ennakkosuoritus"@fi ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "advance payment"@en ,
                           "ennakkosuoritus"@fi ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "advance payment"@en ,
                                                                "ennakkosuoritus"@fi ;
                :relationshipAbbreviation "ENN" .


###  https://kela.fi/ontology/kelao#appealsDecision
:appealsDecision rdf:type owl:ObjectProperty ;
                 rdfs:domain :Appeal ;
                 rdfs:range :Decision ;
                 rdfs:comment "Päätös, johon muutoksenhaku kohdistuu."@fi ,
                              "The decision the appeal is directed against."@en ;
                 rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                 rdfs:label "appeals decision"@en ,
                            "kohdistuu päätökseen"@fi ;
                 <http://www.w3.org/2004/02/skos/core#prefLabel> "appeals decision"@en ,
                                                                 "kohdistuu päätökseen"@fi .


###  https://kela.fi/ontology/kelao#applicationConcerns
:applicationConcerns rdf:type owl:ObjectProperty ;
                     rdfs:domain :Application ;
                     rdfs:range :Benefit ;
                     rdfs:comment "Etuus jota hakemus koskee."@fi ,
                                  "The benefit the application concerns."@en ;
                     rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                     rdfs:label "application concerns"@en ,
                                "hakemus koskee etuutta"@fi ;
                     <http://www.w3.org/2004/02/skos/core#prefLabel> "application concerns"@en ,
                                                                     "hakemus koskee etuutta"@fi .


###  https://kela.fi/ontology/kelao#appliesFor
:appliesFor rdf:type owl:ObjectProperty ;
            rdfs:domain :Applicant ;
            rdfs:range :Benefit ;
            rdfs:comment "Hakija hakee tätä etuutta."@fi ,
                         "The applicant applies for this benefit."@en ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "applies for"@en ,
                       "hakee etuutta"@fi ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "applies for"@en ,
                                                            "hakee etuutta"@fi .


###  https://kela.fi/ontology/kelao#belongsToWellbeingServiceCounty
:belongsToWellbeingServiceCounty rdf:type owl:ObjectProperty ;
                                 rdfs:domain :Municipality ;
                                 rdfs:range :WellbeingServiceCounty ;
                                 rdfs:comment "Belongs to wellbeing service county"@en ,
                                              "Kunta kuuluu tähän hyvinvointialueeseen."@fi ;
                                 rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                                 rdfs:label "belongs to wellbeing service county"@en ,
                                            "kuuluu hyvinvointialueeseen"@fi ;
                                 <http://www.w3.org/2004/02/skos/core#prefLabel> "belongs to wellbeing service county"@en ,
                                                                                 "kuuluu hyvinvointialueeseen"@fi .


