#################################################################

<http://www.w3.org/2004/02/skos/core#changeNote> rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                 rdfs:label "change note"@en ;
                                                 <http://www.w3.org/2004/02/skos/core#definition> "A note about a modification to a concept."@en .


<http://www.w3.org/2004/02/skos/core#scopeNote> rdfs:isDefinedBy <http://www.w3.org/2004/02/skos/core> ;
                                                rdfs:label "scope note"@en ;
                                                <http://www.w3.org/2004/02/skos/core#definition> "A note that helps to clarify the meaning and/or the use of a concept."@en .


:LegalResource rdfs:comment "A work in a legislative corpus. This applies to acts that have been legally enacted (whether or not they are still in force). A legal resource can represent a legal act or any component of a legal act, like an article. Legal resources can be linked together using properties defined in the model."@en ,
                            "Lainsäädäntöaineistoon kuuluva teos. Tämä koskee lainvoimaisesti säädettyjä lakeja (riippumatta siitä, ovatko ne vielä voimassa). Oikeudellinen resurssi voi edustaa säädöstä tai mitä tahansa säädöksen osaa, kuten artiklaa. Oikeudelliset resurssit voidaan linkittää toisiinsa mallissa määriteltyjen ominaisuuksien avulla."@fi ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "Juridisk resurs"@sv ,
                          "Legal Resource"@en ,
                          "Säädös"@fi ;
               <http://www.w3.org/2004/02/skos/core#definition> "Tekstikokonaisuus, joka sisältää julkisen vallan antamia yleisesti noudatettaviksi tarkoitettuja säännöksiä."@fi ,
                                                                "Text containing provisions issued by public authorities that are to be observed generally."@en ;
               <http://www.w3.org/2004/02/skos/core#example> "Examples of statutes are acts and decrees as well as legal provisions issued by authorities."@en ,
                                                             "Säädöksiä ovat esimerkiksi lait ja asetukset sekä viranomaisten antamat oikeussäännöt."@fi .


:LifeSituationClassification rdfs:comment """Elämäntilanteilla tarkoitetaan sellaisia muutosvaiheita, joita kuvaa väliaikaisuus, erityisten palvelujen ja tiedon tarve sekä niihin kohdennetut palvelut.
        Elämäntilanneluokitus on toteutettu muualla skos-luokituksena. Luokituksen luokat ovat käsitteitä. Luokitus on luonnos. Pohjana on käytetty
        DVV:n elämäntapahtumaluokitusta, joka perustuu EU-luokitukseen."""@fi ,
                                          "Life situations refer to phases of change characterized by temporary nature, the need for special services and information, and services targeted to them."@en ;
                             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                             rdfs:label "ElämäntilanneLuokitus"@fi ,
                                        "Klassificering av livssituationer"@sv ,
                                        "Life Situation Classification"@en ;
                             <http://www.w3.org/2004/02/skos/core#definition> "Elämäntilanteilla tarkoitetaan sellaisia muutosvaiheita, joita kuvaa väliaikaisuus, erityisten palvelujen ja tiedon tarve sekä niihin kohdennetut palvelut."@fi ,
                                                                              "Life situations refer to phases of change characterized by temporary nature, the need for special services and information, and services targeted to them."@en ;
                             <http://www.w3.org/2004/02/skos/core#prefLabel> "ElämäntilanneLuokitus"@fi ,
                                                                             "Klassificering av livssituationer"@sv ,
                                                                             "Life Situation Classification"@en .


:Organisation rdfs:comment "An actor that is an association of individuals with a common goal and a purposeful structure"@en ,
                           "Toimija, joka on henkilöiden muodostama yhteenliittymä ja jolla on yhteinen tavoite ja tarkoituksenmukainen rakenne"@fi ;
              rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
              rdfs:label "Organisaatio"@fi ,
                         "Organisation"@sv ,
                         "Organization"@en ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "Organisaatio"@fi ,
                                                              "Organisation"@sv ,
                                                              "Organization"@en ;
              <http://www.w3.org/2004/02/skos/core#scopeNote> """KELAO-kontekstissa vastaa PTV:n Organization-käsitettä ja 
         schema.org/Organization-käsitettä. Käytetään kuvaamaan kaikkia 
         toimijaorganisaatioita sektorirajat ylittäen (julkinen, yksityinen, 
         kolmas sektori). EU Core Public Organisation on tämän erikoistapaus."""@fi .


:Service rdfs:comment "A social-security-related service, e.g. an application or advisory service."@en ,
                      "Sosiaaliturvaan liittyvä palvelu, esim. hakemus- tai neuvontapalvelu."@fi ;
         rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
         rdfs:label "Palvelu"@fi ,
                    "Service"@en ,
                    "Tjänst"@sv ;
         <http://www.w3.org/2004/02/skos/core#definition> "An activity by which a service provider responds to a customer's need."@en ,
                                                          "Toiminto, jolla palveluntoteuttaja vastaa asiakkaan tarpeeseen."@fi ;
         <http://www.w3.org/2004/02/skos/core#prefLabel> "Palvelu"@fi ,
                                                         "Service"@en ,
                                                         "Tjänst"@sv ;
         <http://www.w3.org/2004/02/skos/core#scopeNote> "Ydinmallissa palvelu liitetään etuuteen esim. hakemus- tai neuvontapalveluna (kelao:relatedService). Palvelukanavat ja PTV-metatieto ovat ydinmallin ulkopuolella."@fi .


:alternative rdfs:comment "An established acronym or alternative name for the legal resource."@en ,
                          "Säädöksen vakiintunut lyhenne tai vaihtoehtoinen nimi."@fi ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "lain lyhenne"@fi ,
                        "law acronym"@en ;
             <http://www.w3.org/2004/02/skos/core#prefLabel> "lain lyhenne"@fi ,
                                                             "law acronym"@en ;
             <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:LegalResource-instansseilla. Kuvaa säädöksen vakiintuneen lyhenteen, esim. 'KEL' tai 'SHL'."@fi .


:date_document rdfs:comment "Date of adoption or signature of the legal resource (yyyy-mm-dd)."@en ,
                            "Säädöksen hyväksymis- tai allekirjoituspäivä muodossa vvvv-kk-pp."@fi ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "date of document"@en ,
                          "säädöksen päiväys"@fi ;
               <http://www.w3.org/2004/02/skos/core#prefLabel> "date of document"@en ,
                                                               "säädöksen päiväys"@fi ;
               <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:LegalResource-instansseilla."@fi .


:homepage rdfs:comment "Homepage"@en ,
                       "Kotisivu"@fi ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "homepage"@en ,
                     "kotisivu"@fi ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "homepage"@en ,
                                                          "kotisivu"@fi ;
          <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:Benefit-instansseilla etuuden kotisivuun viittaamisessa."@fi .


:id_local rdfs:comment "National identifier of the legal resource in the form number/year."@en ,
                       "Säädöksen kansallinen tunniste muodossa numero/vuosi."@fi ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "local identifier"@en ,
                     "paikallinen tunniste"@fi ;
          <http://www.w3.org/2004/02/skos/core#prefLabel> "local identifier"@en ,
                                                          "paikallinen tunniste"@fi ;
          <http://www.w3.org/2004/02/skos/core#scopeNote> """Käytetään kelao:LegalResource-instansseilla. 
         Arvo on säädöksen kansallinen numero/vuosi-tunniste, 
         esim. '404/1948' tai '1301/2007'."""@fi .


:identifier rdfs:comment "Official ELI URI identifying the legal resource on Finlex."@en ,
                         "Säädöksen virallinen ELI-URI Finlex-sivulle."@fi ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "identifier"@en ,
                       "tunniste"@fi ;
            <http://www.w3.org/2004/02/skos/core#prefLabel> "identifier"@en ,
                                                            "tunniste"@fi ;
            <http://www.w3.org/2004/02/skos/core#scopeNote> """Käytetään kelao:LegalResource-instansseilla. 
         Arvo on xsd:anyURI-muotoinen ELI-URI Finlex-palveluun, 
         esim. 'https://www.finlex.fi/fi/laki/ajantasa/2007/20071301'."""@fi .


:validFrom rdfs:comment "Början av giltighet"@sv ,
                        "Etuuden voimassaolon alku, milloin Kela tai muu organisaatio alkoi sitä maksamaan."@fi ,
