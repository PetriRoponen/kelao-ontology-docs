                rdfs:comment "Etuudella on osa"@fi ,
                             "Has benefit part"@en ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "etuudella on osa"@fi ,
                           "has benefit part"@en ;
                <http://www.w3.org/2004/02/skos/core#prefLabel> "etuudella on osa"@fi ,
                                                                "has benefit part"@en .


