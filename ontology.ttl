                                                                            "wellbeing service county name"@en ;
                            <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:WellbeingServiceCounty-instansseilla."@fi .


###  https://kela.fi/ontology/kelao#wikidataId
:wikidataId rdf:type owl:DatatypeProperty ;
