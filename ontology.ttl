              rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
              rdfs:label "palvelun aukioloajat"@fi ,
                         "service hours"@en ;
              <http://www.w3.org/2004/02/skos/core#prefLabel> "palvelun aukioloajat"@fi ,
                                                              "service hours"@en ;
              <http://www.w3.org/2004/02/skos/core#scopeNote> "Käytetään kelao:ServiceUnit-instansseilla."@fi .


###  https://kela.fi/ontology/kelao#serviceUnitType
:serviceUnitType rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:string ;
