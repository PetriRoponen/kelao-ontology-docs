        <rdfs:comment xml:lang="en">Processing time in business days (Monday-Friday, excluding holidays). Decimal values allowed (e.g., 5.1 = 5 days and 0.8 hours).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="fi">käsittelyaika arkipäivinä</rdfs:label>
        <rdfs:label xml:lang="en">processing time in business days</rdfs:label>
        <skos:prefLabel xml:lang="fi">käsittelyaika arkipäivinä</skos:prefLabel>
        <skos:prefLabel xml:lang="en">processing time in business days</skos:prefLabel>
        <skos:scopeNote xml:lang="fi">xsd:duration ei kuulu OWL 2 DL -datatyyppikarttaan, mutta on tuettu kaikissa KELAO-kohdejärjestelmissä (GraphDB, Fuseki).</skos:scopeNote>
    </owl:DatatypeProperty>
    


