    </owl:NamedIndividual>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotations
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#changeNote">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">change note</rdfs:label>
        <skos:definition xml:lang="en">A note about a modification to a concept.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="http://www.w3.org/2004/02/skos/core#scopeNote">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">scope note</rdfs:label>
        <skos:definition xml:lang="en">A note that helps to clarify the meaning and/or the use of a concept.</skos:definition>
    </rdf:Description>
    <rdf:Description rdf:about="https://kela.fi/ontology/kelao#LegalResource">
        <rdfs:comment xml:lang="en">A work in a legislative corpus. This applies to acts that have been legally enacted (whether or not they are still in force). A legal resource can represent a legal act or any component of a legal act, like an article. Legal resources can be linked together using properties defined in the model.</rdfs:comment>
        <rdfs:comment xml:lang="fi">Lainsäädäntöaineistoon kuuluva teos. Tämä koskee lainvoimaisesti säädettyjä lakeja (riippumatta siitä, ovatko ne vielä voimassa). Oikeudellinen resurssi voi edustaa säädöstä tai mitä tahansa säädöksen osaa, kuten artiklaa. Oikeudelliset resurssit voidaan linkittää toisiinsa mallissa määriteltyjen ominaisuuksien avulla.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="sv">Juridisk resurs</rdfs:label>
        <rdfs:label xml:lang="en">Legal Resource</rdfs:label>
        <rdfs:label xml:lang="fi">Säädös</rdfs:label>
        <skos:definition xml:lang="fi">Tekstikokonaisuus, joka sisältää julkisen vallan antamia yleisesti noudatettaviksi tarkoitettuja säännöksiä.</skos:definition>
        <skos:definition xml:lang="en">Text containing provisions issued by public authorities that are to be observed generally.</skos:definition>
        <skos:example xml:lang="en">Examples of statutes are acts and decrees as well as legal provisions issued by authorities.</skos:example>
        <skos:example xml:lang="fi">Säädöksiä ovat esimerkiksi lait ja asetukset sekä viranomaisten antamat oikeussäännöt.</skos:example>
    </rdf:Description>
    <rdf:Description rdf:about="https://kela.fi/ontology/kelao#LifeSituationClassification">
        <rdfs:comment xml:lang="fi">Elämäntilanteilla tarkoitetaan sellaisia muutosvaiheita, joita kuvaa väliaikaisuus, erityisten palvelujen ja tiedon tarve sekä niihin kohdennetut palvelut.
        Elämäntilanneluokitus on toteutettu muualla skos-luokituksena. Luokituksen luokat ovat käsitteitä. Luokitus on luonnos. Pohjana on käytetty
        DVV:n elämäntapahtumaluokitusta, joka perustuu EU-luokitukseen.</rdfs:comment>
        <rdfs:comment xml:lang="en">Life situations refer to phases of change characterized by temporary nature, the need for special services and information, and services targeted to them.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="fi">ElämäntilanneLuokitus</rdfs:label>
        <rdfs:label xml:lang="sv">Klassificering av livssituationer</rdfs:label>
        <rdfs:label xml:lang="en">Life Situation Classification</rdfs:label>
        <skos:definition xml:lang="fi">Elämäntilanteilla tarkoitetaan sellaisia muutosvaiheita, joita kuvaa väliaikaisuus, erityisten palvelujen ja tiedon tarve sekä niihin kohdennetut palvelut.</skos:definition>
        <skos:definition xml:lang="en">Life situations refer to phases of change characterized by temporary nature, the need for special services and information, and services targeted to them.</skos:definition>
        <skos:prefLabel xml:lang="fi">ElämäntilanneLuokitus</skos:prefLabel>
        <skos:prefLabel xml:lang="sv">Klassificering av livssituationer</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Life Situation Classification</skos:prefLabel>
    </rdf:Description>
    <rdf:Description rdf:about="https://kela.fi/ontology/kelao#Organisation">
        <rdfs:comment xml:lang="en">An actor that is an association of individuals with a common goal and a purposeful structure</rdfs:comment>
        <rdfs:comment xml:lang="fi">Toimija, joka on henkilöiden muodostama yhteenliittymä ja jolla on yhteinen tavoite ja tarkoituksenmukainen rakenne</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="fi">Organisaatio</rdfs:label>
        <rdfs:label xml:lang="sv">Organisation</rdfs:label>
        <rdfs:label xml:lang="en">Organization</rdfs:label>
        <skos:prefLabel xml:lang="fi">Organisaatio</skos:prefLabel>
        <skos:prefLabel xml:lang="sv">Organisation</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Organization</skos:prefLabel>
        <skos:scopeNote xml:lang="fi">KELAO-kontekstissa vastaa PTV:n Organization-käsitettä ja 
         schema.org/Organization-käsitettä. Käytetään kuvaamaan kaikkia 
         toimijaorganisaatioita sektorirajat ylittäen (julkinen, yksityinen, 
         kolmas sektori). EU Core Public Organisation on tämän erikoistapaus.</skos:scopeNote>
    </rdf:Description>
    <rdf:Description rdf:about="https://kela.fi/ontology/kelao#Service">
        <rdfs:comment xml:lang="en">A social-security-related service, e.g. an application or advisory service.</rdfs:comment>
        <rdfs:comment xml:lang="fi">Sosiaaliturvaan liittyvä palvelu, esim. hakemus- tai neuvontapalvelu.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="fi">Palvelu</rdfs:label>
        <rdfs:label xml:lang="en">Service</rdfs:label>
        <rdfs:label xml:lang="sv">Tjänst</rdfs:label>
        <skos:definition xml:lang="en">An activity by which a service provider responds to a customer&apos;s need.</skos:definition>
        <skos:definition xml:lang="fi">Toiminto, jolla palveluntoteuttaja vastaa asiakkaan tarpeeseen.</skos:definition>
        <skos:prefLabel xml:lang="fi">Palvelu</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Service</skos:prefLabel>
