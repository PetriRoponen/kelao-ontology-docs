    <!-- http://schema.org/legislationDate -->


    <owl:NamedIndividual rdf:about="http://schema.org/legislationDate"/>
    


    <!-- http://schema.org/legislationDateVersion -->


    <owl:NamedIndividual rdf:about="http://schema.org/legislationDateVersion"/>
    


    <!-- http://schema.org/legislationIdentifier -->


    <owl:NamedIndividual rdf:about="http://schema.org/legislationIdentifier"/>
    


