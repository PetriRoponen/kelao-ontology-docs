        <rdfs:comment xml:lang="en">Outcome of the decision.</rdfs:comment>
        <rdfs:comment xml:lang="fi">Päätöksen lopputulos.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="en">decision outcome</rdfs:label>
        <rdfs:label xml:lang="fi">päätöksen lopputulos</rdfs:label>
        <skos:prefLabel xml:lang="en">decision outcome</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">päätöksen lopputulos</skos:prefLabel>
        <skos:scopeNote xml:lang="fi">Käytetään kelao:Decision-instansseilla. Esim. &apos;myönnetty&apos;, &apos;hylätty&apos;, &apos;osittain myönnetty&apos;.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://kela.fi/ontology/kelao#filingDate -->


    <owl:DatatypeProperty rdf:about="https://kela.fi/ontology/kelao#filingDate">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
