    <!-- http://iri.suomi.fi/model/suomiptv2/Service -->


    <owl:NamedIndividual rdf:about="http://iri.suomi.fi/model/suomiptv2/Service"/>
    


    <!-- http://iri.suomi.fi/model/suomiptv2/homePage -->


    <owl:NamedIndividual rdf:about="http://iri.suomi.fi/model/suomiptv2/homePage"/>
    


