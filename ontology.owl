        <skos:prefLabel xml:lang="fi">vireilletulopäivä</skos:prefLabel>
        <skos:scopeNote xml:lang="fi">Käytetään kelao:Application-instansseilla (xsd:date). Päivä jolloin hakemus tuli vireille.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://kela.fi/ontology/kelao#financing -->


    <owl:DatatypeProperty rdf:about="https://kela.fi/ontology/kelao#financing">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">How the financing is organized</rdfs:comment>
        <rdfs:comment xml:lang="sv">Hur finansieringen är organiserad</rdfs:comment>
