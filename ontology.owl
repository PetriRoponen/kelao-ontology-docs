        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="en">financing</rdfs:label>
        <rdfs:label xml:lang="sv">financsieringen</rdfs:label>
        <rdfs:label xml:lang="fi">rahoitus</rdfs:label>
        <skos:prefLabel xml:lang="en">financing</skos:prefLabel>
        <skos:prefLabel xml:lang="sv">financsieringen</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">rahoitus</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- https://kela.fi/ontology/kelao#homepage -->


    <owl:DatatypeProperty rdf:about="https://kela.fi/ontology/kelao#homepage">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Homepage</rdfs:comment>
        <rdfs:comment xml:lang="fi">Kotisivu</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="en">homepage</rdfs:label>
        <rdfs:label xml:lang="fi">kotisivu</rdfs:label>
        <skos:exactMatch rdf:resource="http://iri.suomi.fi/model/suomiptv2/homePage"/>
        <skos:prefLabel xml:lang="en">homepage</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">kotisivu</skos:prefLabel>
        <skos:scopeNote xml:lang="fi">Käytetään kelao:Benefit-instansseilla etuuden kotisivuun viittaamisessa.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://kela.fi/ontology/kelao#id_local -->


    <owl:DatatypeProperty rdf:about="https://kela.fi/ontology/kelao#id_local">
        <rdfs:subPropertyOf rdf:resource="http://data.europa.eu/eli/ontology#id_local"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">National identifier of the legal resource in the form number/year.</rdfs:comment>
        <rdfs:comment xml:lang="fi">Säädöksen kansallinen tunniste muodossa numero/vuosi.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="en">local identifier</rdfs:label>
        <rdfs:label xml:lang="fi">paikallinen tunniste</rdfs:label>
        <skos:exactMatch rdf:resource="http://schema.org/legislationIdentifier"/>
        <skos:prefLabel xml:lang="en">local identifier</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">paikallinen tunniste</skos:prefLabel>
        <skos:scopeNote xml:lang="fi">Käytetään kelao:LegalResource-instansseilla. 
         Arvo on säädöksen kansallinen numero/vuosi-tunniste, 
         esim. &apos;404/1948&apos; tai &apos;1301/2007&apos;.</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://kela.fi/ontology/kelao#identifier -->


    <owl:DatatypeProperty rdf:about="https://kela.fi/ontology/kelao#identifier">
        <rdfs:subPropertyOf rdf:resource="http://purl.org/dc/terms/identifier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">Official ELI URI identifying the legal resource on Finlex.</rdfs:comment>
        <rdfs:comment xml:lang="fi">Säädöksen virallinen ELI-URI Finlex-sivulle.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
        <rdfs:label xml:lang="fi">tunniste</rdfs:label>
        <skos:exactMatch rdf:resource="http://data.europa.eu/eli/ontology#eli"/>
        <skos:exactMatch rdf:resource="http://schema.org/identifier"/>
        <skos:prefLabel xml:lang="en">identifier</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">tunniste</skos:prefLabel>
        <skos:scopeNote xml:lang="fi">Käytetään kelao:LegalResource-instansseilla. 
         Arvo on xsd:anyURI-muotoinen ELI-URI Finlex-palveluun, 
         esim. &apos;https://www.finlex.fi/fi/laki/ajantasa/2007/20071301&apos;.</skos:scopeNote>
    </owl:DatatypeProperty>
    


