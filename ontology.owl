<?xml version="1.0"?>
<rdf:RDF xmlns="https://kela.fi/ontology/kelao#"
     xml:base="https://kela.fi/ontology/kelao"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:kelao="https://kela.fi/ontology/kelao#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://kela.fi/ontology/kelao">
        <owl:imports rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
        <terms:abstract xml:lang="fi">Sosiaaliturvan ontologia kuvaa etuudet, etuuskriteerit, palvelut,  
        organisaatiot, lainsäädännön sekä sosiaaliturvan käsitteet.
        </terms:abstract>
        <terms:abstract xml:lang="en">The Social Security Ontology describes the conceptual structure of the Finnish social security system.
		It is intended to support knowledge graph implementations for policy analysis, eligibility reasoning and data integration. The ontology models relationships between:
        benefits, eligibility criteria, services (benefit related), life situations, organisations, legislation, and concepts.
</terms:abstract>
        <terms:contributor rdf:resource="https://www.linkedin.com/in/petri-roponen-052aa772"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-08</terms:created>
        <terms:creator>Petri Roponen</terms:creator>
        <terms:description xml:lang="en">Core Ontology for Finnish social security concepts: applicants, benefits, eligibility criteria, services, organisations and legislation.</terms:description>
        <terms:description xml:lang="fi">Ydinontologia Suomen sosiaaliturvan keskeisille käsitteille: hakijat, etuudet, etuuskriteerit, palvelut, organisaatiot ja säädökset.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-10</terms:modified>
        <terms:title xml:lang="en">Finnish Social Security Core Ontology</terms:title>
        <terms:title xml:lang="fi">Sosiaaliturvan ydinontologia</terms:title>
        <vann:preferredNamespacePrefix>kelao</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://kela.fi/ontology/kelao#</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="fi">Ydinversio: sisältää vain sosiaaliturvan keskeiset käsitteet (etuudet, kelpoisuus, elämäntilanteet, säädökset, ...).</rdfs:comment>
        <rdfs:label xml:lang="en">Finnish Social Security Core Ontology</rdfs:label>
        <rdfs:label xml:lang="fi">Sosiaaliturvan ydinontologia</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://data.europa.eu/eli/ontology#"/>
        <rdfs:seeAlso rdf:resource="http://data.europa.eu/m8g/"/>
        <rdfs:seeAlso rdf:resource="http://iri.suomi.fi/model/suomiptv2/"/>
        <rdfs:seeAlso rdf:resource="http://purl.org/dc/terms/"/>
        <rdfs:seeAlso rdf:resource="http://purl.org/vocab/cpsv#"/>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/ns/locn#"/>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/ns/org#"/>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/ns/prov#"/>
        <rdfs:seeAlso rdf:resource="http://www.w3.org/ns/shacl#"/>
        <rdfs:seeAlso rdf:resource="https://semiceu.github.io/CPSV-AP/releases/3.2.0/"/>
        <owl:priorVersion>0.1.0</owl:priorVersion>
        <owl:versionInfo>0.2.0-core</owl:versionInfo>
        <skos:changeNote xml:lang="en">Core ontology contains only core classess and properties.</skos:changeNote>
        <skos:changeNote xml:lang="fi">Ydinontologia sisältää ainoastaan ydinluokat ja ominaisuudet.</skos:changeNote>
        <skos:scopeNote xml:lang="fi">Sosiaaliturvan tietämysgraafi (KELAO) ei sisällä hakijakohtaisia tietoja — henkilötiedot käsitellään Kelan operatiivisissa järjestelmissä.</skos:scopeNote>
        <skos:scopeNote xml:lang="en">The Social Security knowledge graph (KELAO) does not contain applicant-level data — personal data is processed in Kela&apos;s operational systems.</skos:scopeNote>
    </owl:Ontology>
    


