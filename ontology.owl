    <!-- http://www.w3.org/2004/02/skos/core#Collection -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Collection">
        <owl:disjointWith rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <owl:disjointWith rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">Collection</rdfs:label>
        <skos:definition xml:lang="en">A meaningful collection of concepts.</skos:definition>
        <skos:scopeNote xml:lang="en">Labelled collections can be used where you would like a set of concepts to be displayed under a &apos;node label&apos; in the hierarchy.</skos:scopeNote>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept">
        <owl:disjointWith rdf:resource="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">Concept</rdfs:label>
        <skos:definition xml:lang="en">An idea or notion; a unit of thought.</skos:definition>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme">
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">Concept Scheme</rdfs:label>
        <skos:definition xml:lang="en">A set of concepts, optionally including statements about semantic relationships between those concepts.</skos:definition>
        <skos:example xml:lang="en">Thesauri, classification schemes, subject heading lists, taxonomies, &apos;folksonomies&apos;, and other types of controlled vocabulary are all examples of concept schemes. Concept schemes are also embedded in glossaries and terminologies.</skos:example>
        <skos:scopeNote xml:lang="en">A concept scheme may be defined to include concepts from different sources.</skos:scopeNote>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#OrderedCollection -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#OrderedCollection">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Collection"/>
        <rdfs:isDefinedBy rdf:resource="http://www.w3.org/2004/02/skos/core"/>
        <rdfs:label xml:lang="en">Ordered Collection</rdfs:label>
        <skos:definition xml:lang="en">An ordered collection of concepts, where both the grouping and the ordering are meaningful.</skos:definition>
        <skos:scopeNote xml:lang="en">Ordered collections can be used where you would like a set of concepts to be displayed in a specific order, and optionally under a &apos;node label&apos;.</skos:scopeNote>
    </owl:Class>
    


    <!-- http://www.w3.org/ns/org#Organization -->


    <owl:Class rdf:about="http://www.w3.org/ns/org#Organization"/>
    


    <!-- http://www.w3.org/ns/prov#Agent -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Agent"/>
    


    <!-- http://www.w3.org/ns/prov#Entity -->


    <owl:Class rdf:about="http://www.w3.org/ns/prov#Entity"/>
    


    <!-- https://kela.fi/ontology/kelao#Appeal -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#Appeal">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="en">Appeal</rdfs:label>
        <rdfs:label xml:lang="fi">Muutoksenhaku</rdfs:label>
        <rdfs:label xml:lang="sv">Ändringssökande</rdfs:label>
        <skos:altLabel xml:lang="fi">oikaisuvaatimus</skos:altLabel>
        <skos:altLabel xml:lang="fi">valitus</skos:altLabel>
        <skos:definition xml:lang="en">An applicant&apos;s request for rectification of or appeal against a decision.</skos:definition>
        <skos:definition xml:lang="fi">Hakijan päätökseen kohdistama oikaisuvaatimus tai valitus.</skos:definition>
        <skos:prefLabel xml:lang="en">Appeal</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">Muutoksenhaku</skos:prefLabel>
        <skos:prefLabel xml:lang="sv">Ändringssökande</skos:prefLabel>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#Applicant -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#Applicant">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="en">Applicant</rdfs:label>
        <rdfs:label xml:lang="fi">Hakija</rdfs:label>
        <rdfs:label xml:lang="sv">Sökande</rdfs:label>
        <skos:definition xml:lang="en">A natural or legal person who applies for a benefit or service, or to whom the right to apply has been transferred.</skos:definition>
        <skos:definition xml:lang="fi">Henkilö tai oikeushenkilö, joka hakee etuutta tai palvelua, tai jolle hakuoikeus on siirtynyt.</skos:definition>
        <skos:prefLabel xml:lang="en">Applicant</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">Hakija</skos:prefLabel>
        <skos:prefLabel xml:lang="sv">Sökande</skos:prefLabel>
        <skos:scopeNote xml:lang="fi">Hakija on prosessirooli. kelao:User on sovelluksen käyttäjä; sama henkilö voi olla molempia.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#Application -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#Application">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="sv">Ansökan</rdfs:label>
        <rdfs:label xml:lang="en">Application</rdfs:label>
        <rdfs:label xml:lang="fi">Hakemus</rdfs:label>
        <skos:definition xml:lang="en">An applicant&apos;s request for a benefit or service. Filing initiates processing of the case.</skos:definition>
        <skos:definition xml:lang="fi">Hakijan etuutta tai palvelua koskeva hakemus. Hakemuksen vireilletulo käynnistää asian käsittelyn.</skos:definition>
        <skos:prefLabel xml:lang="sv">Ansökan</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Application</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">Hakemus</skos:prefLabel>
        <skos:scopeNote xml:lang="en">Conceptual class only. The KELAO knowledge graph does not contain applicant-level instances — personal data is processed in Kela&apos;s operational systems.</skos:scopeNote>
        <skos:scopeNote xml:lang="fi">Käsitteellinen luokka. KELAO-tietämysgraafi ei sisällä hakijakohtaisia instansseja — henkilötiedot käsitellään Kelan operatiivisissa järjestelmissä.</skos:scopeNote>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#Attachment -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#Attachment">
        <rdfs:subClassOf rdf:resource="http://schema.org/DigitalDocument"/>
        <rdfs:comment xml:lang="en">An application attachment, e.g. a receipt, certificate or form.</rdfs:comment>
        <rdfs:comment xml:lang="fi">Hakemuksen liite, esim. tosite, todistus tai lomake.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="en">Attachment</rdfs:label>
        <rdfs:label xml:lang="sv">Bilaga</rdfs:label>
        <rdfs:label xml:lang="fi">Liite</rdfs:label>
        <skos:definition xml:lang="fi">Hakemukseen liitettävä lisämateriaali, joka täydentää tai todentaa hakemuksen tietoja.</skos:definition>
        <skos:definition xml:lang="en">Supplementary material attached to an application that completes or substantiates the application&apos;s information.</skos:definition>
        <skos:prefLabel xml:lang="en">Attachment</skos:prefLabel>
        <skos:prefLabel xml:lang="sv">Bilaga</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">Liite</skos:prefLabel>
        <skos:scopeNote xml:lang="fi">Liitettä tarvitaan joskus hakemuksen liitteeksi; pakollisuus on hakemus- tai etuuskohtaista (kuvataan SHACLissa, ei luokkatasolla).</skos:scopeNote>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#Benefit -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#Benefit">
        <rdfs:subClassOf rdf:resource="http://purl.org/vocab/cpsv#PublicService"/>
        <rdfs:comment xml:lang="en">A social security benefit or allowance. General class — use subclasses for instances.</rdfs:comment>
        <rdfs:comment xml:lang="fi">Sosiaaliturvan etuus tai tuki. Yleinen luokka — käytä alaluokkia instansseissa.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="en">Benefit</rdfs:label>
        <rdfs:label xml:lang="fi">Etuus</rdfs:label>
        <rdfs:label xml:lang="sv">Förmån</rdfs:label>
        <skos:altLabel xml:lang="en">Social benefit</skos:altLabel>
        <skos:altLabel xml:lang="fi">Sosiaalietuus</skos:altLabel>
        <skos:altLabel xml:lang="fi">Tuki</skos:altLabel>
        <skos:prefLabel xml:lang="en">Benefit</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">Etuus</skos:prefLabel>
        <skos:prefLabel xml:lang="sv">Förmån</skos:prefLabel>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#BenefitComponent -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#BenefitComponent">
        <rdfs:subClassOf rdf:resource="https://kela.fi/ontology/kelao#Benefit"/>
        <owl:disjointWith rdf:resource="https://kela.fi/ontology/kelao#StandaloneBenefit"/>
        <rdfs:comment xml:lang="en">Benefit Component</rdfs:comment>
        <rdfs:comment xml:lang="fi">Osa suurempaa etuuskokonaisuutta.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="en">Benefit Component</rdfs:label>
        <rdfs:label xml:lang="fi">Etuuden osa</rdfs:label>
        <skos:altLabel xml:lang="fi">etuusosa</skos:altLabel>
        <skos:altLabel xml:lang="en">sub-benefit</skos:altLabel>
        <skos:definition xml:lang="en">An independent and separately processed part of a benefit that can be granted only if the benefit in which the part belongs is also granted.</skos:definition>
        <skos:definition xml:lang="fi">Etuuden itsenäinen, erikseen käsiteltävä osa, joka voidaan myöntää vain, jos myös etuus, jonka osa on kyseessä, on myönnetty.</skos:definition>
        <skos:example xml:lang="fi">Esimerkiksi opintotuessa etuuden osia ovat opintoraha, asumislisä ja opintolainan valtiontakaus; lesken- ja lapseneläkkeessä osia ovat perus- ja täydennysmäärät.</skos:example>
        <skos:example xml:lang="en">For example, the study grant, housing supplement and government guarantee for student loan are parts of the financial aid for students.</skos:example>
        <skos:prefLabel xml:lang="en">Benefit Component</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">Etuuden osa</skos:prefLabel>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#BenefitGroup -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#BenefitGroup">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Benefit group</rdfs:comment>
        <rdfs:comment xml:lang="fi">Kelan etuusryhmitys</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="en">Benefit Group</rdfs:label>
        <rdfs:label xml:lang="fi">Etuusryhmä</rdfs:label>
        <skos:prefLabel xml:lang="en">Benefit Group</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">Etuusryhmä</skos:prefLabel>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#Decision -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#Decision">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Entity"/>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="sv">Beslut</rdfs:label>
        <rdfs:label xml:lang="en">Decision</rdfs:label>
        <rdfs:label xml:lang="fi">Päätös</rdfs:label>
        <skos:definition xml:lang="en">An authority&apos;s resolution on an application; grants or rejects the requested benefit in full or in part.</skos:definition>
        <skos:definition xml:lang="fi">Viranomaisen ratkaisu hakemukseen; myöntää tai hylkää haetun etuuden kokonaan tai osittain.</skos:definition>
        <skos:prefLabel xml:lang="sv">Beslut</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Decision</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">Päätös</skos:prefLabel>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#LegalResource -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#LegalResource">
        <rdfs:subClassOf rdf:resource="http://data.europa.eu/eli/ontology#LegalResource"/>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#LegalResourcePart -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#LegalResourcePart">
        <rdfs:subClassOf rdf:resource="http://data.europa.eu/eli/ontology#LegalResource"/>
        <rdfs:comment xml:lang="fi">Lain tai asetuksen osa (luku, pykälä, momentti, kohta yms.).
          Tämä luokka on tarkoitettu erottamaan kokonaiset lait niiden osista. EU-asetuksissa ym. on myös muu jaottelu kuin Suomessa.</rdfs:comment>
        <rdfs:comment xml:lang="en">Legal Resource Part</rdfs:comment>
        <rdfs:comment xml:lang="fi">Osa laista riippumatta siitä, onko kyseessä luku, pykälä vai momentti.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="sv">Lagdel</rdfs:label>
        <rdfs:label xml:lang="fi">Lain osa</rdfs:label>
        <rdfs:label xml:lang="en">Legal Resource Part</rdfs:label>
        <skos:definition xml:lang="fi">Lain tai asetuksen osa riippumatta siitä, onko kyseessä luku, pykälä vai momentti</skos:definition>
        <skos:example xml:lang="fi">Kansaneläkelain 23 §</skos:example>
        <skos:prefLabel xml:lang="sv">Lagdel</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">Lain osa</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Legal Resource Part</skos:prefLabel>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#LifeSituationClassification -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#LifeSituationClassification">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#Organisation -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#Organisation">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/org#Organization"/>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#Service -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#Service">
        <rdfs:subClassOf rdf:resource="http://purl.org/vocab/cpsv#PublicService"/>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#StandaloneBenefit -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#StandaloneBenefit">
        <rdfs:subClassOf rdf:resource="https://kela.fi/ontology/kelao#Benefit"/>
        <rdfs:comment xml:lang="fi">Kokonainen, itsenäinen etuus.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="fi">Itsenäinen etuus</rdfs:label>
        <rdfs:label xml:lang="en">Standalone Benefit</rdfs:label>
        <skos:prefLabel xml:lang="fi">Itsenäinen etuus</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Standalone Benefit</skos:prefLabel>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#StatuteType -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#StatuteType">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Statute type classification (draft)</rdfs:comment>
        <rdfs:comment xml:lang="fi">Säädöksen tyyppi määritellään skos-luokituksessa StatuteTypeSkos. Luokitus on luonnos. Sisältää Kelaan soveltuvan sekä suomalaisen että eu-lainsäädännön</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="sv">Författningstyp</rdfs:label>
        <rdfs:label xml:lang="en">Statute Type</rdfs:label>
        <rdfs:label xml:lang="fi">Säädöstyyppi</rdfs:label>
        <skos:prefLabel xml:lang="sv">Författningstyp</skos:prefLabel>
        <skos:prefLabel xml:lang="en">Statute Type</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">Säädöstyyppi</skos:prefLabel>
    </owl:Class>
    


    <!-- https://kela.fi/ontology/kelao#User -->


    <owl:Class rdf:about="https://kela.fi/ontology/kelao#User">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/ns/prov#Agent"/>
        <rdfs:comment xml:lang="en">Application user, user.</rdfs:comment>
        <rdfs:comment xml:lang="fi">Sovelluksen käyttäjä, esim. verkkosovelluksen käyttäjä.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="sv">Användare</rdfs:label>
        <rdfs:label xml:lang="fi">Käyttäjä</rdfs:label>
        <rdfs:label xml:lang="en">User</rdfs:label>
        <skos:definition xml:lang="en">A human actor or agent, user or application user</skos:definition>
        <skos:definition xml:lang="fi">Sovelluksen käyttäjä, agentti tms.</skos:definition>
        <skos:prefLabel xml:lang="sv">Användare</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">Käyttäjä</skos:prefLabel>
        <skos:prefLabel xml:lang="en">User</skos:prefLabel>
    </owl:Class>
    


