    <!-- https://kela.fi/ontology/kelao#processingTime -->


    <owl:DatatypeProperty rdf:about="https://kela.fi/ontology/kelao#processingTime">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#duration"/>
        <rdfs:comment xml:lang="fi">Etuuden keskimääräinen käsittelyaika päivinä hakemuksen saapumisesta. Joissain tapauksissa kyse on arkipäivistä esim. 5,1 arkipäivää.</rdfs:comment>
        <rdfs:comment xml:lang="en">Typical time required to process the benefit application.</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="https://kela.fi/ontology/kelao"/>
        <rdfs:label xml:lang="sv">handläggningstid</rdfs:label>
        <rdfs:label xml:lang="fi">käsittelyaika</rdfs:label>
        <rdfs:label xml:lang="en">processing time</rdfs:label>
        <skos:prefLabel xml:lang="sv">handläggningstid</skos:prefLabel>
        <skos:prefLabel xml:lang="fi">käsittelyaika</skos:prefLabel>
        <skos:prefLabel xml:lang="en">processing time</skos:prefLabel>
        <skos:scopeNote xml:lang="fi">xsd:duration ei kuulu OWL 2 DL -datatyyppikarttaan, mutta on tuettu kaikissa KELAO-kohdejärjestelmissä (GraphDB, Fuseki).</skos:scopeNote>
    </owl:DatatypeProperty>
    


    <!-- https://kela.fi/ontology/kelao#processingTimeBusinessDays -->


    <owl:DatatypeProperty rdf:about="https://kela.fi/ontology/kelao#processingTimeBusinessDays">
