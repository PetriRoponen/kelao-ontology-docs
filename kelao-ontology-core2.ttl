                    "taxable"@en ,
                    "verotettava"@fi ;
         skos:note "Tiedot löytyvät myös sivulta https://www.kela.fi/verotus"@fi ;
         skos:prefLabel "beskattningsbar"@sv ,
                               "taxable"@en ,
                               "verotettava"@fi .


