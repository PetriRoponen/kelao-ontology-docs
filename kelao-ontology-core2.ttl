@prefix : <https://kela.fi/ontology/kelao#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix schema: <http://schema.org/> .
@prefix eli: <http://data.europa.eu/eli/ontology#> .
@prefix cpsv: <http://purl.org/vocab/cpsv#> .
@prefix org: <http://www.w3.org/ns/org#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix locn: <http://www.w3.org/ns/locn#> .
@prefix geo: <http://www.w3.org/2003/01/geo/wgs84_pos#> .
@prefix ptv: <http://iri.suomi.fi/model/suomiptv2/> .
@prefix m8g: <http://data.europa.eu/m8g/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@base <https://kela.fi/ontology/kelao#> .

<https://kela.fi/ontology/kelao> rdf:type owl:Ontology ;
        owl:versionIRI <https://petriroponen.github.io/kelao-ontology-docs/> ;
        dct:abstract """Sosiaaliturvan ydinontologia kuvaa etuudet, etuuskriteerit, palvelut,  
        organisaatiot, maantieteelliset alueet, palvelukanavat, tietotuotteet, lainsäädännön sekä sosiaaliturvan käsitteet.
        """@fi ,
        """The Social Security Core Ontology describes the conceptual structure of the Finnish social security system.
	It is intended to support knowledge graph implementations for policy analysis, eligibility reasoning and data integration. The ontology models relationships between:
        benefits, eligibility criteria, services, life situations, organisations, legislation, and concepts.
"""@en ;
        dct:contributor <https://www.linkedin.com/in/petri-roponen-052aa772> ;
        dct:created "2026-06-08"^^xsd:date ;
        dct:creator "Petri Roponen" ;
        dct:description "Core Ontology for Finnish social security concepts: applicants, benefits, eligibility criteria, services, organisations and legislation."@en ,
                "This is a draft version. Content is subject to change."@en ,
                "Tämä on luonnosversio (Draft). Sisältö voi muuttua."@fi ,
                "Ydinontologia Suomen sosiaaliturvan keskeisille käsitteille: hakijat, etuudet, etuuskriteerit, palvelut, organisaatiot ja säädökset."@fi ;
        dct:license <https://creativecommons.org/licenses/by/4.0/> ;
        dct:modified "2026-06-17"^^xsd:date ;
        dct:title "Finnish Social Security Core Ontology"@en ,
                   "Sosiaaliturvan ydinontologia"@fi ;
        vann:preferredNamespacePrefix "kelao" ;
        vann:preferredNamespaceUri "https://kela.fi/ontology/kelao#"^^xsd:anyURI ;
        rdfs:comment "Ydinversio sisältää vain sosiaaliturvan keskeiset käsitteet (etuudet, kelpoisuus, elämäntilanteet, säädökset, ...)."@fi ;
        rdfs:label "Finnish Social Security Core Ontology"@en ,
                    "Sosiaaliturvan ydinontologia"@fi ;
        rdfs:seeAlso eli: ,
                     m8g: ,
                     ptv: ,
                     dct: ,
                     cpsv: ,
                     schema: ,
                     geo: ,
                     locn: ,
                     org: ,
                     prov: ,
                     <http://www.w3.org/ns/shacl#> ,
                     <https://semiceu.github.io/CPSV-AP/releases/3.2.0/> ;
        owl:priorVersion "0.2.0-core-draft" ;
        owl:versionInfo "0.3.0-core-draft" ;
        skos:changeNote "Automated document generation"@en ,
                         "Automatisoitu dokumentaation luonti .ttl-tiedostosta"@fi ,
                         "0.3.0: lisätty maantieteelliset alueet (Location, Municipality, WellbeingServiceCounty, Region, Country), palvelukanava (ServiceChannel) ja palvelupiste (ServiceUnit) sekä tietotuote (DataProduct) relaatioineen ja ominaisuuksineen."@fi ;
        skos:scopeNote "Sosiaaliturvan tietämysgraafi (KELAO) ei sisällä hakijakohtaisia tietoja — henkilötiedot käsitellään Kelan operatiivisissa järjestelmissä."@fi ,
                        "The Social Security knowledge graph (KELAO) does not contain applicant-level data — personal data is processed in Kela's operational systems."@en .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/abstract
dct:abstract rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/contributor
dct:contributor rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dct:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
dct:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dct:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
dct:license rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/modified
dct:modified rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
dct:title rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespacePrefix
vann:preferredNamespacePrefix rdf:type owl:AnnotationProperty .


###  http://purl.org/vocab/vann/preferredNamespaceUri
vann:preferredNamespaceUri rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#broadMatch
skos:broadMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#changeNote
skos:changeNote rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#closeMatch
skos:closeMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#example
skos:example rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#note
skos:note rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#prefLabel
skos:prefLabel rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#scopeNote
skos:scopeNote rdf:type owl:AnnotationProperty .


###  https://kela.fi/ontology/kelao#alternative
:alternative rdf:type owl:AnnotationProperty ;
             rdfs:subPropertyOf skos:altLabel .


###  https://kela.fi/ontology/kelao#relationshipAbbreviation
:relationshipAbbreviation rdf:type owl:AnnotationProperty ;
        rdfs:comment "Relaation lyhenne"@fi ,
                    "Relationship abbreviation"@en ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "Relaation lyhenne"@fi ,
                   "Relationship abbreviation"@en ;
        skos:prefLabel "Relaation lyhenne"@fi ,
                       "Relationship abbreviation"@en .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


###  http://www.w3.org/2001/XMLSchema#duration
xsd:duration rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://data.europa.eu/eli/ontology#has_part
eli:has_part rdf:type owl:ObjectProperty .


###  http://data.europa.eu/eli/ontology#type_document
eli:type_document rdf:type owl:ObjectProperty .


###  http://schema.org/hasPart
schema:hasPart rdf:type owl:ObjectProperty .


###  http://schema.org/legislationType
schema:legislationType rdf:type owl:ObjectProperty .


###  https://kela.fi/ontology/kelao#advancePayment
:advancePayment rdf:type owl:ObjectProperty ;
                rdfs:domain :Benefit ;
                rdfs:range :Benefit ;
                rdfs:comment "Advance payment"@en ,
                             "Ennakkosuoritus"@fi ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "advance payment"@en ,
                           "ennakkosuoritus"@fi ;
                skos:prefLabel "advance payment"@en ,
                        "ennakkosuoritus"@fi ;
                :relationshipAbbreviation "ENN" .


###  https://kela.fi/ontology/kelao#appealsDecision
:appealsDecision rdf:type owl:ObjectProperty ;
                 rdfs:domain :Appeal ;
                 rdfs:range :Decision ;
                 rdfs:comment "Päätös, johon muutoksenhaku kohdistuu."@fi ,
                              "The decision the appeal is directed against."@en ;
                 rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                 rdfs:label "appeals decision"@en ,
                            "kohdistuu päätökseen"@fi ;
                 skos:prefLabel "appeals decision"@en ,
                        "kohdistuu päätökseen"@fi .


###  https://kela.fi/ontology/kelao#applicationConcerns
:applicationConcerns rdf:type owl:ObjectProperty ;
                     rdfs:domain :Application ;
                     rdfs:range :Benefit ;
                     rdfs:comment "Etuus jota hakemus koskee."@fi ,
                                  "The benefit the application concerns."@en ;
                     rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                     rdfs:label "application concerns"@en ,
                                "hakemus koskee etuutta"@fi ;
                     skos:prefLabel "application concerns"@en ,
                            "hakemus koskee etuutta"@fi .


###  https://kela.fi/ontology/kelao#appliesFor
:appliesFor rdf:type owl:ObjectProperty ;
            rdfs:domain :Applicant ;
            rdfs:range :Benefit ;
            rdfs:comment "Hakija hakee tätä etuutta."@fi ,
                         "The applicant applies for this benefit."@en ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "applies for"@en ,
                       "hakee etuutta"@fi ;
            skos:prefLabel "applies for"@en ,
                    "hakee etuutta"@fi .


###  https://kela.fi/ontology/kelao#broaderBenefit
:broaderBenefit rdf:type owl:ObjectProperty ;
                rdfs:domain :Benefit ;
                rdfs:range :Benefit ;
                rdfs:comment "Broader benefit"@en ,
                             "Laajempi etuus"@fi ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "broader benefit"@en ,
                           "laajempi etuus"@fi ;
                skos:prefLabel "broader benefit"@en ,
                        "laajempi etuus"@fi .


###  https://kela.fi/ontology/kelao#hasApplication
:hasApplication rdf:type owl:ObjectProperty ;
                rdfs:domain :Applicant ;
                rdfs:range :Application ;
                rdfs:comment "An application submitted by the applicant."@en ,
                             "Hakijan jättämä hakemus."@fi ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "has application"@en ,
                           "jätti hakemuksen"@fi ;
                skos:prefLabel "has application"@en ,
                        "jätti hakemuksen"@fi .


###  https://kela.fi/ontology/kelao#hasAttachment
:hasAttachment rdf:type owl:ObjectProperty ;
               rdfs:domain :Application ;
               rdfs:range :Attachment ;
               rdfs:comment "An attachment belonging to the application."@en ,
                            "Hakemukseen liittyvä liite."@fi ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "hakemuksen liite"@fi ,
                          "has attachment"@en ;
               skos:prefLabel "hakemuksen liite"@fi ,
                        "has attachment"@en .


###  https://kela.fi/ontology/kelao#hasBenefitGroup
:hasBenefitGroup rdf:type owl:ObjectProperty ;
                 rdfs:domain :Benefit ;
                 rdfs:range :BenefitGroup ;
                 rdfs:comment "Etuusryhmä"@fi ,
                              "Has benefit group"@en ;
                 rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                 rdfs:label "etuusryhmä"@fi ,
                            "has benefit group"@en ;
                 skos:prefLabel "etuusryhmä"@fi ,
                        "has benefit group"@en .


###  https://kela.fi/ontology/kelao#hasBenefitPart
:hasBenefitPart rdf:type owl:ObjectProperty ;
                owl:inverseOf :isPartOfBenefit ;
                rdfs:domain :StandaloneBenefit ;
                rdfs:range :BenefitComponent ;
                rdfs:comment "Etuudella on osa"@fi ,
                             "Has benefit part"@en ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "etuudella on osa"@fi ,
                           "has benefit part"@en ;
                skos:prefLabel "etuudella on osa"@fi ,
                        "has benefit part"@en .


###  https://kela.fi/ontology/kelao#hasConcept
:hasConcept rdf:type owl:ObjectProperty ;
            rdfs:domain :Benefit ;
            rdfs:range skos:Concept ;
            rdfs:comment "Has concept"@en ,
                         "On käsite"@fi ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "has concept"@en ,
                       "on käsite"@fi ;
            skos:prefLabel "has concept"@en ,
                        "on käsite"@fi .


###  https://kela.fi/ontology/kelao#hasDecision
:hasDecision rdf:type owl:ObjectProperty ;
             rdfs:domain :Application ;
             rdfs:range :Decision ;
             rdfs:comment "Hakemukseen annettu päätös."@fi ,
                          "The decision issued on the application."@en ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "hakemuksen päätös"@fi ,
                        "has decision"@en ;
             skos:prefLabel "hakemuksen päätös"@fi ,
                                   "has decision"@en .


###  https://kela.fi/ontology/kelao#hasProvider
:hasProvider rdf:type owl:ObjectProperty ;
             rdfs:domain :Benefit ;
             rdfs:range :Organisation ;
             rdfs:comment "Has provider"@en ,
                          "Vastuuorganisaatio"@fi ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "has provider"@en ,
                        "vastuuorganisaatio"@fi ;
             skos:prefLabel "has provider"@en ,
                                   "vastuuorganisaatio"@fi .


###  https://kela.fi/ontology/kelao#has_part
:has_part rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf eli:has_part ,
                             schema:hasPart ;
          rdfs:domain :LegalResource ;
          rdfs:range :LegalResource ;
          rdfs:comment "Lain tai muun säädöksen osa esim. pykälä."@fi ,
                       "Statute has part"@en ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "has part"@en ,
                     "on osa säädöstä"@fi ,
                     "är del av"@sv ;
          skos:prefLabel "has part"@en ,
                                "on osa säädöstä"@fi ,
                                "är del av"@sv .


###  https://kela.fi/ontology/kelao#inhibiting
:inhibiting rdf:type owl:ObjectProperty ;
            rdfs:domain :Benefit ;
            rdfs:range :Benefit ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "estävä etuus"@fi ,
                       "hindrande förmån"@sv ,
                       "inhibiting benefit"@en ;
            rdfs:seeAlso <https://iri.suomi.fi/terminology/kela/c66> ;
            skos:definition "förmån som ska beaktas och på grund av vilken den förmånssökande inte beviljas en annan förmån"@sv ,
                                   "huomioon otettava etuus, jonka vuoksi etuudenhakijalle ei myönnetä jotain toista etuutta"@fi ;
            skos:exactMatch <https://iri.suomi.fi/terminology/kela/c66> ;
            skos:prefLabel "estävä etuus"@fi ,
                                  "hindrande förmån"@sv ,
                                  "inhibiting benefit"@en ;
            :relationshipAbbreviation "EST" .


###  https://kela.fi/ontology/kelao#investigate
:investigate rdf:type owl:ObjectProperty ;
             rdfs:domain :Benefit ;
             rdfs:range :Benefit ;
             rdfs:comment "Benefit to investigate"@en ,
                          "Selvitä etuus"@fi ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "benefit to investigate"@en ,
                        "selvitä etuus"@fi ;
             skos:prefLabel "benefit to investigate"@en ,
                                   "selvitä etuus"@fi ;
             :relationshipAbbreviation "SEL" .


###  https://kela.fi/ontology/kelao#isEligibleFor
:isEligibleFor rdf:type owl:ObjectProperty ;
               rdfs:domain :User ;
               rdfs:range :Benefit ;
               rdfs:comment "Käyttäjä tai hakija on todettu oikeutetuksi etuuteen validoinnin tai päätöksen perusteella."@fi ,
                            "User or applicant has been determined eligible for the benefit."@en ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "is eligible for"@en ,
                          "on oikeutettu etuuteen"@fi ;
               skos:prefLabel "is eligible for"@en ,
                        "on oikeutettu etuuteen"@fi .


###  https://kela.fi/ontology/kelao#isLifeSituationFor
:isLifeSituationFor rdf:type owl:ObjectProperty ;
                    rdfs:domain :LifeSituationClassification ;
                    rdfs:range :Benefit ;
                    rdfs:comment "Is life situation for"@en ,
                                 "On elämäntilanne kohteelle"@fi ;
                    rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                    rdfs:label "is life situation for"@en ,
                               "on elämäntilanne kohteelle"@fi ;
                    skos:prefLabel "is life situation for"@en ,
                            "on elämäntilanne kohteelle"@fi .


###  https://kela.fi/ontology/kelao#isPartOfBenefit
:isPartOfBenefit rdf:type owl:ObjectProperty ;
                 rdfs:domain :BenefitComponent ;
                 rdfs:range :StandaloneBenefit ;
                 rdfs:comment "Is part of benefit"@en ,
                              "On osa etuutta"@fi ;
                 rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                 rdfs:label "is part of benefit"@en ,
                            "on osa etuutta"@fi ;
                 skos:prefLabel "is part of benefit"@en ,
                            "on osa etuutta"@fi .


###  https://kela.fi/ontology/kelao#legalReference
:legalReference rdf:type owl:ObjectProperty ;
                rdfs:domain :Benefit ;
                rdfs:range :LegalResource ;
                rdfs:comment "Etuus tai palvelu perustuu tähän lakiin tai säädökseen."@fi ,
                             "Has legal reference"@en ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "has legal reference"@en ,
                           "on lakiviittaus"@fi ;
                skos:prefLabel "has legal reference"@en ,
                                      "on lakiviittaus"@fi .


###  https://kela.fi/ontology/kelao#meansTestedIncome
:meansTestedIncome rdf:type owl:ObjectProperty ;
                   rdfs:domain :Benefit ;
                   rdfs:range :Benefit ;
                   rdfs:comment "Means-tested income"@en ,
                                "Tarveharkinnan tulo"@fi ;
                   rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                   rdfs:label "means-tested income"@en ,
                              "tarveharkinnan tulo"@fi ;
                   skos:prefLabel "means-tested income"@en ,
                                  "tarveharkinnan tulo"@fi .


###  https://kela.fi/ontology/kelao#minimumAmount
:minimumAmount rdf:type owl:ObjectProperty ;
               rdfs:domain :Benefit ;
               rdfs:range :Benefit ;
               rdfs:comment "Minimimääräinen etuus"@fi ,
                            "Minimum amount benefit"@en ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "minimimääräinen etuus"@fi ,
                          "minimum amount benefit"@en ;
               skos:prefLabel "minimimääräinen etuus"@fi ,
                              "minimum amount benefit"@en ;
               :relationshipAbbreviation "MIN" .


###  https://kela.fi/ontology/kelao#noteworthy
:noteworthy rdf:type owl:ObjectProperty ;
            rdfs:domain :Benefit ;
            rdfs:range :Benefit ;
            rdfs:comment "Benefit to be noted"@en ,
                         "Huomautus"@fi ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "benefit to be noted"@en ,
                       "huomautus"@fi ;
            skos:prefLabel "benefit to be noted"@en ,
                           "huomautus"@fi ;
            :relationshipAbbreviation "HUO" .


###  https://kela.fi/ontology/kelao#reducing
:reducing rdf:type owl:ObjectProperty ;
          rdfs:domain :Benefit ;
          rdfs:range :Benefit ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "reducing benefit"@en ,
                     "vähentävä etuus"@fi ;
          rdfs:seeAlso <https://iri.suomi.fi/terminology/kela/c65> ;
          skos:definition "förmån som ska beaktas och som minskar beloppet av en annan förmån"@sv ,
                        "huomioon otettava etuus, joka vähentää toisen etuuden määrää"@fi ;
          skos:exactMatch <https://iri.suomi.fi/terminology/kela/c65> ;
          skos:prefLabel "reducing benefit"@en ,
                         "vähentävä etuus"@fi ;
          :relationshipAbbreviation "VÄH" .


###  https://kela.fi/ontology/kelao#relatedBenefit
:relatedBenefit rdf:type owl:ObjectProperty ;
                rdfs:domain :LegalResource ;
                rdfs:range :Benefit ;
                rdfs:comment "Has related benefit"@en ,
                             "Yhteys etuuteen"@fi ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "has related benefit"@en ,
                           "säädös tai vaatimusprofiili koskee etuutta"@fi ;
                skos:prefLabel "has related benefit"@en ,
                                      "säädös tai vaatimusprofiili koskee etuutta"@fi .


###  https://kela.fi/ontology/kelao#relatedService
:relatedService rdf:type owl:ObjectProperty ;
                rdfs:domain :Benefit ;
                rdfs:range :Service ;
                rdfs:comment "A service related to the benefit, e.g. an application or advisory service."@en ,
                             "Etuuteen liittyvä palvelu, esim. hakemus- tai neuvontapalvelu."@fi ;
                rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                rdfs:label "etuuteen liittyvä palvelu"@fi ,
                           "related service"@en ;
                skos:prefLabel "etuuteen liittyvä palvelu"@fi ,
                                      "related service"@en .


###  https://kela.fi/ontology/kelao#relatedToLifeSituation
:relatedToLifeSituation rdf:type owl:ObjectProperty ;
                        owl:inverseOf :isLifeSituationFor ;
                        rdfs:domain :Benefit ;
                        rdfs:range :LifeSituationClassification ;
                        rdfs:comment "Liittyy elämäntilanteeseen"@fi ,
                                     "Related to life situation"@en ;
                        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                        rdfs:label "liittyy elämäntilanteeseen"@fi ,
                                   "related to life situation"@en ;
                        skos:prefLabel "liittyy elämäntilanteeseen"@fi ,
                                              "related to life situation"@en .


###  https://kela.fi/ontology/kelao#type_document
:type_document rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf eli:type_document ,
                                  schema:legislationType ;
               rdfs:domain :LegalResource ;
               rdfs:range :StatuteType ;
               rdfs:comment "Lain tai muun säädöksen tyyppi"@fi ,
                            "Statute type"@en ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
