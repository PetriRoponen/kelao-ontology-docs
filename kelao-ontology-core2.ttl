#################################################################
#    Classes
#################################################################

###  http://data.europa.eu/eli/ontology#LegalResource
eli:LegalResource rdf:type owl:Class .


###  http://purl.org/vocab/cpsv#PublicService
cpsv:PublicService rdf:type owl:Class .


###  http://schema.org/DigitalDocument
schema:DigitalDocument rdf:type owl:Class .


###  http://www.w3.org/2004/02/skos/core#Concept
skos:Concept rdf:type owl:Class .


###  http://www.w3.org/ns/org#Organization
org:Organization rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Agent
prov:Agent rdf:type owl:Class .


###  http://www.w3.org/ns/prov#Entity
prov:Entity rdf:type owl:Class .


###  https://kela.fi/ontology/kelao#Appeal
:Appeal rdf:type owl:Class ;
        rdfs:subClassOf prov:Entity ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "Appeal"@en ,
                "Muutoksenhaku"@fi ,
                "Ändringssökande"@sv ;
        skos:altLabel "oikaisuvaatimus"@fi ,
                "valitus"@fi ;
        skos:definition "An applicant's request for rectification of or appeal against a decision."@en ,
                "Hakijan päätökseen kohdistama oikaisuvaatimus tai valitus."@fi ;
        skos:prefLabel "Appeal"@en ,
                "Muutoksenhaku"@fi ,
                "Ändringssökande"@sv .


###  https://kela.fi/ontology/kelao#Applicant
:Applicant rdf:type owl:Class ;
        rdfs:subClassOf prov:Agent ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "Applicant"@en ,
                "Hakija"@fi ,
                "Sökande"@sv ;
        skos:definition "A natural or legal person who applies for a benefit or service, or to whom the right to apply has been transferred."@en ,
                "Henkilö tai oikeushenkilö, joka hakee etuutta tai palvelua, tai jolle hakuoikeus on siirtynyt."@fi ;
        skos:prefLabel "Applicant"@en ,
                "Hakija"@fi ,
                "Sökande"@sv ;
        skos:scopeNote "Hakija on prosessirooli. kelao:User on sovelluksen käyttäjä; sama henkilö voi olla molempia."@fi .


###  https://kela.fi/ontology/kelao#Application
:Application rdf:type owl:Class ;
        rdfs:subClassOf prov:Entity ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "Ansökan"@sv ,
                "Application"@en ,
                "Hakemus"@fi ;
        rdfs:seeAlso <https://iri.suomi.fi/terminology/kela/c77> ;
        skos:altLabel "Ansökan om förmån"@sv ,
                "Etuushakemus"@fi ,
                "Förmånsansökan"@sv ;
        skos:definition "An applicant's request for a benefit or service. Filing initiates processing of the case."@en ,
                "Asiakirja, jolla etuudenhakijalle esittää pyynnön tai hänen puolestaan ja hänen suostumuksellaan esitetään pyyntö saada jotain etuutta."@fi ,
                "Hakijan etuutta tai palvelua koskeva hakemus. Hakemuksen vireilletulo käynnistää asian käsittelyn. Etuushakemus on hakemuksen alaluokka."@fi ;
        skos:prefLabel "Ansökan"@sv ,
                "Application"@en ,
                "Hakemus"@fi ;
        skos:scopeNote "Conceptual class only. The KELAO knowledge graph does not contain applicant-level instances — personal data is processed in Kela's operational systems."@en ,
                "Käsitteellinen luokka. KELAO-tietämysgraafi ei sisällä hakijakohtaisia instansseja — henkilötiedot käsitellään Kelan operatiivisissa järjestelmissä."@fi .


###  https://kela.fi/ontology/kelao#Attachment
:Attachment rdf:type owl:Class ;
        rdfs:subClassOf schema:DigitalDocument ;
        rdfs:comment "An application attachment, e.g. a receipt, certificate or form."@en ,
                "Hakemuksen liite, esim. tosite, todistus tai lomake."@fi ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "Attachment"@en ,
                "Bilaga"@sv ,
                "Liite"@fi ;
        skos:definition "Hakemukseen liitettävä lisämateriaali, joka täydentää tai todentaa hakemuksen tietoja."@fi ,
                "Supplementary material attached to an application that completes or substantiates the application's information."@en ;
        skos:prefLabel "Attachment"@en ,
                "Bilaga"@sv ,
                "Liite"@fi ;
        skos:scopeNote "Liitettä tarvitaan joskus hakemuksen liitteeksi; pakollisuus on hakemus- tai etuuskohtaista (kuvataan SHACLissa, ei luokkatasolla)."@fi .


###  https://kela.fi/ontology/kelao#Benefit
:Benefit rdf:type owl:Class ;
         rdfs:subClassOf cpsv:PublicService ;
         rdfs:comment "A social security benefit or allowance. General class — use subclasses for instances."@en ,
                "FPA:s förmåner är sociala förmåner. Ibland används också termen socialförsäkringsförmåner."@sv ,
                "Sosiaaliturvan etuus tai tuki. Yleinen luokka — käytä alaluokkia instansseissa. Kelan etuudet ovat sosiaalietuuksia. Joskus käytetään myös termiä sosiaaliturvaetuus."@fi ;
         rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
         rdfs:label "Benefit"@en ,
                "Etuus"@fi ,
                "Förmån"@sv ;
         rdfs:seeAlso <https://iri.suomi.fi/terminology/verotus/c66> ;
         skos:altLabel "Social benefit"@en ,
                "Sosiaalietuus"@fi ,
                "Tuki"@fi ;
         skos:definition "Nyttighet vars ekonomiska värde kan fastställas och som beviljas utgående från mottagarens ställning eller livssituation på grunder som fastställts i förväg."@sv ,
                """Taloudelliselta arvoltaan määriteltävissä oleva hyödyke, joka myönnetään saajan aseman tai elämäntilanteen perusteella ennalta määritellyin perustein.
            Verotus: suoritus, joka maksetaan saajan aseman tai elämäntilanteen perusteella ennalta määritellyin perustein
            """@fi ,
                "x"@en ;
         skos:exactMatch <https://iri.suomi.fi/terminology/kela/c60> ;
         skos:prefLabel "Benefit"@en ,
                "Etuus"@fi ,
                "Förmån"@sv .


###  https://kela.fi/ontology/kelao#BenefitComponent
:BenefitComponent rdf:type owl:Class ;
        rdfs:subClassOf :Benefit ;
        owl:disjointWith :StandaloneBenefit ;
        rdfs:comment "Benefit Component"@en ,
                "Osa suurempaa etuuskokonaisuutta."@fi ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "Benefit Component"@en ,
                             "Etuuden osa"@fi ;
        skos:altLabel "etuusosa"@fi , "sub-benefit"@en ;
        skos:definition "An independent and separately processed part of a benefit that can be granted only if the benefit in which the part belongs is also granted."@en ,
                "Etuuden itsenäinen, erikseen käsiteltävä osa, joka voidaan myöntää vain, jos myös etuus, jonka osa on kyseessä, on myönnetty."@fi ;
        skos:example "Esimerkiksi opintotuessa etuuden osia ovat opintoraha, asumislisä ja opintolainan valtiontakaus; lesken- ja lapseneläkkeessä osia ovat perus- ja täydennysmäärät."@fi ,
                "For example, the study grant, housing supplement and government guarantee for student loan are parts of the financial aid for students."@en ;
        skos:prefLabel "Benefit Component"@en ,
                "Etuuden osa"@fi .


###  https://kela.fi/ontology/kelao#BenefitGroup
:BenefitGroup rdf:type owl:Class ;
        rdfs:subClassOf skos:Concept ;
        rdfs:comment "Benefit group"@en ,
                "Kelan etuusryhmitys"@fi ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "Benefit Group"@en ,
                "Etuusryhmä"@fi ;
        skos:prefLabel "Benefit Group"@en ,
                "Etuusryhmä"@fi .


###  https://kela.fi/ontology/kelao#Decision
:Decision rdf:type owl:Class ;
          rdfs:subClassOf prov:Entity ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "Beslut"@sv ,
                "Decision"@en ,
                "Päätös"@fi ;
          rdfs:seeAlso <https://iri.suomi.fi/terminology/kela/c78> ;
          skos:altLabel "beslut om förmån"@sv ,
                "etuuspäätös"@fi ,
                "förmånsbeslut"@sv ;
          skos:definition "An authority's resolution on an application; grants or rejects the requested benefit in full or in part."@en ,
                "Viranomaisen ratkaisu hakemukseen; myöntää tai hylkää haetun etuuden kokonaan tai osittain."@fi ;
          skos:prefLabel "Beslut"@sv ,
                "Decision"@en ,
                "Päätös"@fi .


###  https://kela.fi/ontology/kelao#LegalResource
:LegalResource rdf:type owl:Class ;
               rdfs:subClassOf eli:LegalResource ;
               rdfs:comment "A work in a legislative corpus. This applies to acts that have been legally enacted (whether or not they are still in force). A legal resource can represent a legal act or any component of a legal act, like an article. Legal resources can be linked together using properties defined in the model."@en ,
                            "Lainsäädäntöaineistoon kuuluva teos. Tämä koskee lainvoimaisesti säädettyjä lakeja (riippumatta siitä, ovatko ne vielä voimassa). Oikeudellinen resurssi voi edustaa säädöstä tai mitä tahansa säädöksen osaa, kuten artiklaa. Oikeudelliset resurssit voidaan linkittää toisiinsa mallissa määriteltyjen ominaisuuksien avulla."@fi ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "Juridisk resurs"@sv ,
                          "Legal Resource"@en ,
                          "Säädös"@fi ;
               skos:definition "Tekstikokonaisuus, joka sisältää julkisen vallan antamia yleisesti noudatettaviksi tarkoitettuja säännöksiä."@fi ,
                        "Text containing provisions issued by public authorities that are to be observed generally."@en ;
               skos:exactMatch schema:Legislation ;
               skos:example "Examples of statutes are acts and decrees as well as legal provisions issued by authorities."@en ,
                        "Säädöksiä ovat esimerkiksi lait ja asetukset sekä viranomaisten antamat oikeussäännöt."@fi .


###  https://kela.fi/ontology/kelao#LegalResourcePart
:LegalResourcePart rdf:type owl:Class ;
        rdfs:subClassOf eli:LegalResource ;
        rdfs:comment """Lain tai asetuksen osa (luku, pykälä, momentti, kohta yms.).
          Tämä luokka on tarkoitettu erottamaan kokonaiset lait niiden osista. EU-asetuksissa ym. on myös muu jaottelu kuin Suomessa."""@fi ,
                "Legal Resource Part"@en ,
                "Osa laista riippumatta siitä, onko kyseessä luku, pykälä vai momentti."@fi ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "Lagdel"@sv ,
                "Lain osa"@fi ,
                "Legal Resource Part"@en ;
        skos:definition "Lain tai asetuksen osa riippumatta siitä, onko kyseessä luku, pykälä vai momentti"@fi ;
        skos:example "Kansaneläkelain 23 §"@fi ;
        skos:prefLabel "Lagdel"@sv ,
                "Lain osa"@fi ,
                "Legal Resource Part"@en .


###  https://kela.fi/ontology/kelao#LifeSituationClassification
:LifeSituationClassification rdf:type owl:Class ;
                rdfs:subClassOf skos:Concept ;
                rdfs:comment """Elämäntilanteilla tarkoitetaan sellaisia muutosvaiheita, joita kuvaa väliaikaisuus, erityisten palvelujen ja tiedon tarve sekä niihin kohdennetut palvelut.
        Elämäntilanneluokitus on toteutettu muualla skos-luokituksena. Luokituksen luokat ovat käsitteitä. Luokitus on luonnos. Pohjana on käytetty
        DVV:n elämäntapahtumaluokitusta, joka perustuu EU-luokitukseen."""@fi ,
        "Life situations refer to phases of change characterized by temporary nature, the need for special services and information, and services targeted to them."@en ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "ElämäntilanneLuokitus"@fi ,
                "Klassificering av livssituationer"@sv ,
                "Life Situation Classification"@en ;
        skos:closeMatch ptv:LifeEventClassification ;
        skos:definition "Elämäntilanteilla tarkoitetaan sellaisia muutosvaiheita, joita kuvaa väliaikaisuus, erityisten palvelujen ja tiedon tarve sekä niihin kohdennetut palvelut."@fi ,
                "Life situations refer to phases of change characterized by temporary nature, the need for special services and information, and services targeted to them."@en ;
        skos:prefLabel "ElämäntilanneLuokitus"@fi ,
                "Klassificering av livssituationer"@sv ,
                "Life Situation Classification"@en .


###  https://kela.fi/ontology/kelao#Organisation
:Organisation rdf:type owl:Class ;
        rdfs:subClassOf org:Organization ;
        rdfs:comment "An actor that is an association of individuals with a common goal and a purposeful structure"@en ,
                "Toimija, joka on henkilöiden muodostama yhteenliittymä ja jolla on yhteinen tavoite ja tarkoituksenmukainen rakenne"@fi ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "Organisaatio"@fi ,
                "Organisation"@sv ,
                "Organization"@en ;
        skos:broadMatch m8g:PublicOrganisation ;
        skos:closeMatch foaf:Organization ;
        skos:exactMatch ptv:Organization , schema:Organization ;
        skos:prefLabel "Organisaatio"@fi ,
                "Organisation"@sv ,
                "Organization"@en ;
        skos:scopeNote """KELAO-kontekstissa vastaa PTV:n Organization-käsitettä ja 
        schema.org/Organization-käsitettä. Käytetään kuvaamaan kaikkia 
         toimijaorganisaatioita sektorirajat ylittäen (julkinen, yksityinen, 
         kolmas sektori). EU Core Public Organisation on tämän erikoistapaus."""@fi .


###  https://kela.fi/ontology/kelao#Service
:Service rdf:type owl:Class ;
         rdfs:subClassOf cpsv:PublicService ;
         rdfs:comment "A social-security-related service, e.g. an application or advisory service."@en ,
                      "Sosiaaliturvaan liittyvä palvelu, esim. hakemus- tai neuvontapalvelu."@fi ;
         rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
         rdfs:label "Palvelu"@fi ,
                "Service"@en ,
                "Tjänst"@sv ;
         skos:definition "An activity by which a service provider responds to a customer's need."@en ,
                "Toiminto, jolla palveluntoteuttaja vastaa asiakkaan tarpeeseen."@fi ;
         skos:exactMatch ptv:Service ;
         skos:prefLabel "Palvelu"@fi ,
                "Service"@en ,
                "Tjänst"@sv ;
         skos:scopeNote "Ydinmallissa palvelu liitetään etuuteen (kelao:relatedService) ja se on käytettävissä palvelukanavien kautta (kelao:hasServiceChannel). Palvelukanava (kelao:ServiceChannel) ja palvelupiste (kelao:ServiceUnit) kuuluvat ydinmalliin; laajempi PTV-metatieto (esim. rahoitustyyppi, palveluluokitus, kohderyhmät) jää edelleen ydinmallin ulkopuolelle."@fi ,
                "In the core model a service is linked to a benefit (kelao:relatedService) and is accessible through service channels (kelao:hasServiceChannel). Service channels (kelao:ServiceChannel) and service units (kelao:ServiceUnit) are part of the core model; broader PTV metadata (e.g. funding type, service classification, target groups) remains outside it."@en .


###  https://kela.fi/ontology/kelao#StandaloneBenefit
:StandaloneBenefit rdf:type owl:Class ;
                   rdfs:subClassOf :Benefit ;
                   rdfs:comment "Kokonainen, itsenäinen etuus."@fi ;
                   rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                   rdfs:label "Itsenäinen etuus"@fi ,
                              "Standalone Benefit"@en ;
                   skos:prefLabel "Itsenäinen etuus"@fi ,
                                         "Standalone Benefit"@en .


###  https://kela.fi/ontology/kelao#StatuteType
:StatuteType rdf:type owl:Class ;
             rdfs:subClassOf skos:Concept ;
             rdfs:comment "Statute type classification (draft). The Skos-classification has 13 classes for example EU regulation, Decree, Agreement, Government decree, and Presidential decree."@en ,
                          "Säädöksen tyyppi määritellään skos-luokituksessa StatuteType. Luokitus on luonnos. Sisältää Kelaan soveltuvan sekä suomalaisen että eu-lainsäädännön"@fi ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "Författningstyp"@sv ,
                        "Statute Type"@en ,
                        "Säädöstyyppi"@fi ;
             skos:prefLabel "Författningstyp"@sv ,
                                   "Statute Type"@en ,
                                   "Säädöstyyppi"@fi .


###  https://kela.fi/ontology/kelao#User
:User rdf:type owl:Class ;
      rdfs:subClassOf prov:Agent ;
      rdfs:comment "Application user, user."@en ,
                   "Sovelluksen käyttäjä, esim. verkkosovelluksen käyttäjä."@fi ;
      rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
      rdfs:label "Användare"@sv ,
                 "Käyttäjä"@fi ,
                 "User"@en ;
      skos:definition "A human actor or agent, user or application user"@en ,
                                                       "Sovelluksen käyttäjä, agentti tms."@fi ;
      skos:prefLabel "Användare"@sv ,
                                                      "Käyttäjä"@fi ,
                                                      "User"@en .


###  https://kela.fi/ontology/kelao#Country
:Country rdf:type owl:Class ;
         rdfs:subClassOf :Location ;
         rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
         rdfs:comment "A country / state. Used e.g. to express residence requirements and cross-border situations."@en ,
                      "Valtio. Käytetään esim. asumisedellytyksen ja kansainvälisten tilanteiden kuvaamiseen."@fi ;
         rdfs:label "Country"@en ,
                    "Valtio"@fi ,
                    "Stat"@sv ;
         skos:exactMatch schema:Country ;
         skos:prefLabel "Country"@en ,
                               "Valtio"@fi ,
                               "Stat"@sv ;
         skos:scopeNote "Lähdeontologiassa kuvattu suoraan schema:Country-luokkana; ydinmallissa määritelty omana luokkana ja linkitetty skos:exactMatch-suhteella."@fi .


###  https://kela.fi/ontology/kelao#DataProduct
:DataProduct rdf:type owl:Class ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:comment "A managed and governed collection of data with a purpose, value, ownership and life-cycle that meets consumer needs, e.g. a report or other benefit-related data product."@en ,
                "Hallittu ja omistettu tietokokonaisuus, jolla on tarkoitus, arvo ja elinkaari ja joka vastaa tiedon hyödyntäjän tarpeisiin. Esimerkiksi raportti tai muu etuuteen liittyvä tietotuote."@fi ;
        rdfs:label "Data Product"@en ,
                "Informationsprodukt"@sv ,
                "Tietotuote"@fi ;
        skos:definition "A data product is a product that facilitates an end goal through the use of data."@en ,
                "Tietotuote on tuote, joka helpottaa lopputavoitteen saavuttamista datan avulla."@fi ;
        skos:prefLabel "Data Product"@en ,
                "Informationsprodukt"@sv ,
                "Tietotuote"@fi ;
        skos:scopeNote "Itsenäinen luokka. Mahdollinen linkitys ulkoiseen data product -sanastoon (esim. DPROD) jätetty myöhempään harmonisointiin."@fi .


###  https://kela.fi/ontology/kelao#Location
:Location rdf:type owl:Class ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:comment "A geographic area used e.g. to describe a place of residence, a service operating area, or the location of a service unit. Superclass for municipalities, wellbeing service counties, regions and countries."@en ,
                "Maantieteellinen alue, jota voidaan käyttää esim. asuinpaikan, palvelun toiminta-alueen tai palvelupisteen sijainnin kuvaamiseen. Yliluokka kunnille, hyvinvointialueille, maakunnille ja valtioille."@fi ;
        rdfs:label "Location"@en ,
                "Plats"@sv ,
                "Sijainti"@fi ;
        skos:altLabel "Geographic Area"@en , "Place"@en ,
                 "Maantieteellinen alue"@fi ;
        skos:closeMatch locn:Location ;
        skos:definition "Any geographic area, irrespective of size or administrative level."@en ,
                "Mikä tahansa maantieteellinen alue koosta tai hallinnollisesta tasosta riippumatta."@fi ;
        skos:definition "Union of all the geo classes"@en, "A spatial region or named place"@en ; 
        skos:prefLabel "Location"@en ,
                "Plats"@sv ,
                "Sijainti"@fi ;
        skos:scopeNote "Ydinmallissa nimi on harmonisoitu Location-muotoon ja linkitetty W3C Location Core -sanastoon (locn:Location)."@fi .


###  https://kela.fi/ontology/kelao#Municipality
:Municipality rdf:type owl:Class ;
        rdfs:subClassOf :Location ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:comment "A Finnish municipality. Municipalities are identified using Suomi.fi code list URIs."@en ,
                "Suomen kunta. Kunnat tunnistetaan Suomi.fi-koodiston URI-tunnisteilla."@fi ;
        rdfs:label "Municipality"@en ,
                "Kommun"@sv ,
                "Kunta"@fi ;
        skos:prefLabel "Municipality"@en ,
                "Kommun"@sv ,
                "Kunta"@fi ;
        skos:scopeNote "Suomen kunnat, Suomi.fi URI:t."@fi .


###  https://kela.fi/ontology/kelao#Region
:Region rdf:type owl:Class ;
        rdfs:subClassOf :Location ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:comment "A region (maakunta): an areal unit of regional development and planning composed of municipalities."@en ,
                     "Maakunta. Kuntien muodostama alueellisen kehittämisen ja suunnittelun yksikkö."@fi ;
        rdfs:label "Maakunta"@fi ,
                   "Region"@en ,
                   "Landskap"@sv ;
        skos:prefLabel "Maakunta"@fi ,
                "Region"@en ,
                "Landskap"@sv .


###  https://kela.fi/ontology/kelao#ServiceChannel
:ServiceChannel rdf:type owl:Class ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:comment "A service channel: the way a customer accesses a service, e.g. e-service, web page, printable form, telephone service or a physical service point. A single service may have several alternative or sequential channels."@en ,
                "Palvelu- tai asiointikanava: tapa, jolla asiakas saa palvelun käyttöönsä. Kanava voi olla esimerkiksi verkkoasiointi, verkkosivu, tulostettava lomake, puhelinasiointi tai fyysinen palvelupaikka. Yhdellä palvelulla voi olla useita vaihtoehtoisia tai peräkkäisiä kanavia."@fi ;
        rdfs:label "Palvelukanava"@fi ,
                "Service Channel"@en ,
                "Servicekanal"@sv ;
        skos:closeMatch ptv:ServiceChannel ;
        skos:definition "Tapa, jolla asiakas saa palvelun käyttöönsä."@fi ,
                "The way in which a customer accesses a service."@en ;
        skos:prefLabel "Palvelukanava"@fi ,
                "Service Channel"@en ,
                "Servicekanal"@sv ;
        skos:scopeNote "Linkitetty PTV:n ServiceChannel-käsitteeseen vain skos:closeMatch-suhteella, koska ptv: on epävakaa nimiavaruus."@fi .


###  https://kela.fi/ontology/kelao#ServiceUnit
:ServiceUnit rdf:type owl:Class ;
             rdfs:subClassOf :ServiceChannel ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:comment "A service unit (service point) with a physical location. Service unit data has been combined from Kela's internal sources and PTV service-channel data (entity matching)."@en ,
                """Palvelupisteet voivat olla sekä yksityisten että julkishallinnon toimijoiden ylläpitämiä. Vrt. asiointipiste.
Joissain palvelupisteissä on asiakastietokoneita, joilla asiakkaat voivat asioida myös itsenäisesti.
Kelan palvelupisteissä tarjotaan Kelan palveluja, ja niissä työskentelee Kelan palveluasiantuntijoita. Kelan palvelupiste voi sijaita myös muualla kuin Kelan omissa tiloissa.
Palvelupiste, jolla on fyysinen sijainti. Palvelupisteiden tiedot on yhdistetty Kelan sisäisestä lähteestä ja PTV:n palvelukanavatiedoista (entity matching)."""@fi ;
             rdfs:label "Palvelupiste"@fi ,
                        "Service Unit"@en ,
                        "Serviceställe"@sv ;
             skos:altLabel "Palvelupiste"@fi ;
             skos:closeMatch ptv:ServiceChannel ;
             skos:definition "A physically located service point at which a service is provided."@en ,
                        "Toimipiste, jota ylläpitää pääsääntöisesti yksi toimija ja jossa voi saada kyseisen toimijan tai muiden toimijoiden tarjoamia palveluja."@fi ;
             skos:prefLabel "Palvelupiste"@fi ,
                        "Service Unit"@en ,
                        "Serviceställe"@sv ;
             skos:scopeNote "Palvelupiste on palvelukanavan erikoistapaus, siksi rdfs:subClassOf kelao:ServiceChannel."@fi .


###  https://kela.fi/ontology/kelao#WellbeingServiceCounty
:WellbeingServiceCounty rdf:type owl:Class ;
        rdfs:subClassOf :Location ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:comment "A wellbeing services county: a self-governing area responsible for organising health, social and rescue services in Finland."@en ,
                "Hyvinvointialue. Suomen sosiaali- ja terveydenhuollon sekä pelastustoimen järjestämisestä vastaava itsehallinnollinen alue."@fi ;
        rdfs:label "Hyvinvointialue"@fi ,
                "Wellbeing Service County"@en ,
                "Välfärdsområde"@sv ;
        skos:prefLabel "Hyvinvointialue"@fi ,
                "Wellbeing Service County"@en ,
                "Välfärdsområde"@sv .


