###  https://kela.fi/ontology/kelao#hasServiceChannel
:hasServiceChannel rdf:type owl:ObjectProperty ;
                   rdfs:domain :Service ;
                   rdfs:range :ServiceChannel ;
                   rdfs:comment "A service has service channels. Services are accessible through service channels."@en ,
                                "Palvelulla on palvelukanava. Palvelu on käytettävissä palvelukanavien kautta."@fi ;
                   rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                   rdfs:label "has channel"@en ,
