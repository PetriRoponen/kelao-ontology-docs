            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "maximum age"@en ,
                       "yläikäraja"@fi ,
                       "åldersgräns"@sv ;
            skos:prefLabel "maximum age"@en ,
                                  "yläikäraja"@fi ,
                                  "åldersgräns"@sv .


###  https://kela.fi/ontology/kelao#meansTest
:meansTest rdf:type owl:DatatypeProperty ;
           rdfs:range xsd:string ;
           rdfs:comment "Determining entitlement to benefits requires a means test."@en ,
                        "Etuuden oikeuden päättely edellyttää tarveharkintaa, tarveharkinnan selitys."@fi ,
                        "För att fastställa rätten till förmåner krävs en behovsprövning."@sv ;
           rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
           rdfs:label "behovsprövning"@sv ,
                      "means test"@en ,
                      "tarveharkinta"@fi ;
           skos:definition "Etuuksien tai palvelujen myöntämisen kriteerien soveltaminen henkilön tarpeeseen."@fi ,
                                  "Tillämpning av kriterierna för beviljande av förmåner eller service på en persons behov."@sv ;
           skos:exactMatch <https://iri.suomi.fi/terminology/kela/c688> ;
           skos:prefLabel "behovsprövning"@sv ,
                                 "means test"@en ,
                                 "tarveharkinta"@fi .


