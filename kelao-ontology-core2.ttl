             rdfs:comment "Päivämäärä, jolloin säädöksen tämä versio on voimassa."@fi ,
                          "The point-in-time at which the provided description of the legislation is valid."@en ;
             rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
             rdfs:label "versiointipäivä"@fi ,
                        "version date"@en ;
             skos:exactMatch schema:legislationDateVersion ;
             skos:prefLabel "versiointipäivä"@fi ,
                                   "version date"@en ;
             skos:scopeNote "Käytetään kelao:LegalResource-instansseilla. Kuvaa hetken, jolloin säädöksen kyseinen versio on voimassa."@fi .


