                        "Hur finansieringen är organiserad"@sv ,
                        "Kuinka rahoitus on järjestetty"@fi ;
           rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
           rdfs:label "financing"@en ,
                      "financsieringen"@sv ,
                      "rahoitus"@fi ;
           skos:prefLabel "financing"@en ,
                                 "financsieringen"@sv ,
                                 "rahoitus"@fi .


###  https://kela.fi/ontology/kelao#homepage
:homepage rdf:type owl:DatatypeProperty ;
          rdfs:range xsd:anyURI ;
          rdfs:comment "Homepage"@en ,
                       "Kotisivu"@fi ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "homepage"@en ,
                     "kotisivu"@fi ;
          skos:exactMatch ptv:homePage ;
          skos:prefLabel "homepage"@en ,
                                "kotisivu"@fi ;
          skos:scopeNote "Käytetään kelao:Benefit-instansseilla etuuden kotisivuun viittaamisessa."@fi .


###  https://kela.fi/ontology/kelao#id_local
:id_local rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf eli:id_local ;
          rdfs:range xsd:string ;
          rdfs:comment "National identifier of the legal resource in the form number/year."@en ,
                       "Säädöksen kansallinen tunniste muodossa numero/vuosi."@fi ;
          rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
          rdfs:label "local identifier"@en ,
                     "paikallinen tunniste"@fi ;
          skos:exactMatch schema:legislationIdentifier ;
          skos:prefLabel "local identifier"@en ,
                                "paikallinen tunniste"@fi ;
          skos:scopeNote """Käytetään kelao:LegalResource-instansseilla. 
         Arvo on säädöksen kansallinen numero/vuosi-tunniste, 
         esim. '404/1948' tai '1301/2007'."""@fi .


###  https://kela.fi/ontology/kelao#identifier
:identifier rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf dct:identifier ;
            rdfs:range xsd:anyURI ;
            rdfs:comment "Official ELI URI identifying the legal resource on Finlex."@en ,
                         "Säädöksen virallinen ELI-URI Finlex-sivulle."@fi ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "identifier"@en ,
                       "tunniste"@fi ;
            skos:exactMatch eli:eli ,
                                   schema:identifier ;
            skos:prefLabel "identifier"@en ,
                                  "tunniste"@fi ;
            skos:scopeNote """Käytetään kelao:LegalResource-instansseilla. 
         Arvo on xsd:anyURI-muotoinen ELI-URI Finlex-palveluun, 
         esim. 'https://www.finlex.fi/fi/laki/ajantasa/2007/20071301'."""@fi .


###  https://kela.fi/ontology/kelao#indexLinked
:indexLinked rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:string ;
             rdfs:comment "Index linked"@en ,
