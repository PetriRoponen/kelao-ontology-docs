                skos:prefLabel "handläggningstid"@sv ,
                                      "käsittelyaika"@fi ,
                                      "processing time"@en ;
                skos:scopeNote "xsd:duration ei kuulu OWL 2 DL -datatyyppikarttaan, mutta on tuettu kaikissa KELAO-kohdejärjestelmissä (GraphDB, Fuseki)."@fi .


