dct:identifier rdf:type owl:DatatypeProperty .


###  http://schema.org/amount
schema:amount rdf:type owl:DatatypeProperty .


###  http://schema.org/identifier
schema:identifier rdf:type owl:DatatypeProperty .


###  https://kela.fi/ontology/kelao#abbreviation
:abbreviation rdf:type owl:DatatypeProperty ;
              rdfs:range xsd:string ;
              rdfs:comment "Internal abbreviation used by Kela for the benefit."@en ,
                           "Kelan sisäisesti käyttämä etuuden lyhenne"@fi ;
              rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
              rdfs:label "abbreviation"@en ,
                         "lyhenne"@fi ;
              skos:prefLabel "abbreviation"@en ,
                                    "lyhenne"@fi .


###  https://kela.fi/ontology/kelao#alternative
:alternative rdf:type owl:DatatypeProperty ;
             rdfs:range xsd:string .


###  https://kela.fi/ontology/kelao#amount
:amount rdf:type owl:DatatypeProperty ;
        rdfs:subPropertyOf schema:amount ;
        rdfs:range xsd:string ;
        rdfs:comment "Rahallinen määrä."@fi ,
                     "The amount of money."@en ;
        rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
        rdfs:label "amount"@en ,
                   "määrä"@fi ;
        skos:prefLabel "amount"@en ,
                              "määrä"@fi .


###  https://kela.fi/ontology/kelao#appealDate
:appealDate rdf:type owl:DatatypeProperty ;
            rdfs:range xsd:date ;
            rdfs:comment "Date the appeal was filed."@en ,
                         "Päivä jolloin muutoksenhaku jätettiin."@fi ;
            rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
            rdfs:label "appeal date"@en ,
                       "muutoksenhaun päivä"@fi ;
            skos:prefLabel "appeal date"@en ,
                                  "muutoksenhaun päivä"@fi ;
            skos:scopeNote "Käytetään kelao:Appeal-instansseilla (xsd:date)."@fi .


###  https://kela.fi/ontology/kelao#applicationStatus
:applicationStatus rdf:type owl:DatatypeProperty ;
                   rdfs:range xsd:string ;
                   rdfs:comment "Hakemuksen käsittelyvaiheen tila."@fi ,
                                "Processing status of the application."@en ;
                   rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                   rdfs:label "application status"@en ,
                              "hakemuksen tila"@fi ;
                   skos:prefLabel "application status"@en ,
                                         "hakemuksen tila"@fi ;
                   skos:scopeNote "Käytetään kelao:Application-instansseilla. Esim. 'vireillä', 'käsittelyssä', 'ratkaistu'."@fi .


###  https://kela.fi/ontology/kelao#attachmentInOmaKela
:attachmentInOmaKela rdf:type owl:DatatypeProperty ;
                     rdfs:range xsd:boolean ;
                     rdfs:comment "Onko liite haettavissa tai ilmoitettavissa OmaKelassa."@fi ,
                                  "Whether the attachment can be requested or reported in OmaKela."@en ;
                     rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                     rdfs:label "is attachment in OmaKela"@en ,
                                "onko liite OmaKelassa"@fi ;
                     skos:prefLabel "is attachment in OmaKela"@en ,
                                     "onko liite OmaKelassa"@fi ;
                     skos:scopeNote "Käytetään kelao:Attachment-instansseilla (xsd:boolean)."@fi .


###  https://kela.fi/ontology/kelao#attachmentUri
:attachmentUri rdf:type owl:DatatypeProperty ;
               rdfs:range xsd:anyURI ;
               rdfs:comment "URI link to where the attachment can be found."@en ,
                            "URI-linkki liitteeseen, josta liite löytyy."@fi ;
               rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
               rdfs:label "attachment uri"@en ,
                          "liitteen uri"@fi ;
               skos:prefLabel "attachment uri"@en ,
                         "liitteen uri"@fi ;
               skos:scopeNote "Käytetään kelao:Attachment-instansseilla (xsd:anyURI)."@fi .


###  https://kela.fi/ontology/kelao#calculationBase
:calculationBase rdf:type owl:DatatypeProperty ;
                 rdfs:range xsd:string ;
                 rdfs:comment "Calculation base"@en ,
                              "Laskentaperuste"@fi ;
                 rdfs:isDefinedBy <https://kela.fi/ontology/kelao> ;
                 rdfs:label "calculation base"@en ,
                            "laskentaperuste"@fi ;
                 skos:definition "Miten etuuden määrä lasketaan"@fi ;
                 skos:prefLabel "calculation base"@en ,
                                       "laskentaperuste"@fi .


###  https://kela.fi/ontology/kelao#currentVersion
:currentVersion rdf:type owl:DatatypeProperty ;
                rdfs:range xsd:anyURI ;
